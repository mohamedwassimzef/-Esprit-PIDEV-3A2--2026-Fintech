<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="tn.esprit.controllers.LoginController"
           prefWidth="900" prefHeight="700"
           style="-fx-background-color: #F3F4F6;">

    <ScrollPane fitToWidth="true" fitToHeight="false"
                style="-fx-background-color: transparent; -fx-background: transparent;">

        <VBox alignment="TOP_CENTER" spacing="0">
            <padding><Insets top="30" bottom="30"/></padding>

            <!-- ===== CARD ===== -->
            <VBox alignment="TOP_CENTER" maxWidth="440" spacing="0"
                  style="-fx-background-color: white; -fx-background-radius: 20;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0, 0, 5);">

                <!-- HEADER -->
                <HBox alignment="CENTER" prefHeight="80"
                      style="-fx-background-color: #1E3A8A; -fx-background-radius: 20 20 0 0;">
                    <Label text="💳 FinTech Portal"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                </HBox>

                <!-- TABS -->
                <HBox spacing="0" prefHeight="50">
                    <Button fx:id="btnSignInTab" text="Sign In"
                            prefWidth="220" prefHeight="50"
                            style="-fx-background-color: #1E3A8A; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-font-size: 14px;
                                   -fx-background-radius: 0; -fx-cursor: hand;"
                            onAction="#showSignIn"/>
                    <Button fx:id="btnSignUpTab" text="Sign Up"
                            prefWidth="220" prefHeight="50"
                            style="-fx-background-color: #E5E7EB; -fx-text-fill: #6B7280;
                                   -fx-font-weight: bold; -fx-font-size: 14px;
                                   -fx-background-radius: 0; -fx-cursor: hand;"
                            onAction="#showSignUp"/>
                </HBox>

                <!-- ===== SIGN IN PANE ===== -->
                <VBox fx:id="signInPane" spacing="12" visible="true" managed="true">
                    <padding><Insets top="28" right="35" bottom="28" left="35"/></padding>

                    <Label text="Welcome back 👋"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1E3A8A;"/>

                    <Label text="Email"
                           style="-fx-font-size: 13px; -fx-text-fill: #374151; -fx-font-weight: bold;"/>
                    <TextField fx:id="loginEmail" promptText="Enter your email"
                               style="-fx-background-radius: 10; -fx-border-color: #D1D5DB;
                                      -fx-border-radius: 10; -fx-padding: 10;"/>

                    <Label text="Password"
                           style="-fx-font-size: 13px; -fx-text-fill: #374151; -fx-font-weight: bold;"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <PasswordField fx:id="loginPassword" promptText="Enter your password"
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-background-radius: 10; -fx-border-color: #D1D5DB;
                                              -fx-border-radius: 10; -fx-padding: 10;"/>
                        <TextField fx:id="loginPasswordVisible" promptText="Enter your password"
                                   HBox.hgrow="ALWAYS" visible="false" managed="false"
                                   style="-fx-background-radius: 10; -fx-border-color: #D1D5DB;
                                          -fx-border-radius: 10; -fx-padding: 10;"/>
                        <Button fx:id="loginToggleBtn" text="👁" prefWidth="40" prefHeight="40"
                                style="-fx-background-color: #E5E7EB; -fx-background-radius: 10;
                                       -fx-cursor: hand; -fx-font-size: 14px;"
                                onAction="#toggleLoginPassword"/>
                    </HBox>

                    <Button text="Forgot password?"
                            style="-fx-background-color: transparent; -fx-text-fill: #1E3A8A;
                                   -fx-cursor: hand; -fx-font-size: 12px; -fx-border-color: transparent;"
                            onAction="#handleForgotPassword"/>

                    <!-- ✅ reCAPTCHA WebView (Sign In) -->
                    <Label text="Please verify you're human:"
                           style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"/>
                    <WebView fx:id="signInCaptchaView" prefHeight="90" prefWidth="370"
                             style="-fx-background-color: transparent;"/>

                    <Label fx:id="loginMessage" text="" wrapText="true"
                           style="-fx-font-size: 13px; -fx-font-weight: bold;"/>

                    <Button text="Sign In →" prefWidth="370" prefHeight="45"
                            style="-fx-background-color: #1E3A8A; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-font-size: 15px;
                                   -fx-background-radius: 12; -fx-cursor: hand;"
                            onAction="#handleSignIn"/>

                    <!-- Divider -->
                    <HBox alignment="CENTER" spacing="10">
                        <Separator HBox.hgrow="ALWAYS"/>
                        <Label text="or continue with"
                               style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF;"/>
                        <Separator HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <!-- Alternative login buttons -->
                    <HBox spacing="10" alignment="CENTER">
                        <Button fx:id="googleSignInBtn" text="🌐  Sign in with Google"
                                prefWidth="178" prefHeight="42"
                                style="-fx-background-color: white; -fx-text-fill: #374151;
                                       -fx-border-color: #D1D5DB; -fx-border-radius: 10;
                                       -fx-background-radius: 10; -fx-font-size: 13px;
                                       -fx-cursor: hand; -fx-font-weight: bold;"
                                onAction="#handleGoogleSignIn"/>
                        <Button text="🤳  Sign in with Face"
                                prefWidth="178" prefHeight="42"
                                style="-fx-background-color: #7C3AED; -fx-text-fill: white;
                                       -fx-border-radius: 10; -fx-background-radius: 10;
                                       -fx-font-size: 13px; -fx-cursor: hand; -fx-font-weight: bold;"
                                onAction="#handleFaceLogin"/>
                    </HBox>
                </VBox>

                <!-- ===== SIGN UP PANE ===== -->
                <VBox fx:id="signUpPane" spacing="12" visible="false" managed="false">
                    <padding><Insets top="25" right="35" bottom="25" left="35"/></padding>

                    <Label text="Create an account 🚀"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1E3A8A;"/>

                    <Label text="Full Name"
                           style="-fx-font-size: 13px; -fx-text-fill: #374151; -fx-font-weight: bold;"/>
                    <TextField fx:id="signUpName" promptText="Your full name"
                               style="-fx-background-radius: 10; -fx-border-color: #D1D5DB;
                                      -fx-border-radius: 10; -fx-padding: 10;"/>

                    <Label text="Email"
                           style="-fx-font-size: 13px; -fx-text-fill: #374151; -fx-font-weight: bold;"/>
                    <TextField fx:id="signUpEmail" promptText="Your email address"
                               style="-fx-background-radius: 10; -fx-border-color: #D1D5DB;
                                      -fx-border-radius: 10; -fx-padding: 10;"/>

                    <Label text="Phone"
                           style="-fx-font-size: 13px; -fx-text-fill: #374151; -fx-font-weight: bold;"/>
                    <TextField fx:id="signUpPhone" promptText="8-digit phone number"
                               style="-fx-background-radius: 10; -fx-border-color: #D1D5DB;
                                      -fx-border-radius: 10; -fx-padding: 10;"/>

                    <Label text="Password"
                           style="-fx-font-size: 13px; -fx-text-fill: #374151; -fx-font-weight: bold;"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <PasswordField fx:id="signUpPassword" promptText="At least 6 characters"
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-background-radius: 10; -fx-border-color: #D1D5DB;
                                              -fx-border-radius: 10; -fx-padding: 10;"/>
                        <TextField fx:id="signUpPasswordVisible" promptText="At least 6 characters"
                                   HBox.hgrow="ALWAYS" visible="false" managed="false"
                                   style="-fx-background-radius: 10; -fx-border-color: #D1D5DB;
                                          -fx-border-radius: 10; -fx-padding: 10;"/>
                        <Button fx:id="signUpToggleBtn" text="👁" prefWidth="40" prefHeight="40"
                                style="-fx-background-color: #E5E7EB; -fx-background-radius: 10;
                                       -fx-cursor: hand; -fx-font-size: 14px;"
                                onAction="#toggleSignUpPassword"/>
                    </HBox>

                    <!-- ✅ reCAPTCHA WebView (Sign Up) -->
                    <Label text="Please verify you're human:"
                           style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"/>
                    <WebView fx:id="signUpCaptchaView" prefHeight="90" prefWidth="370"
                             style="-fx-background-color: transparent;"/>

                    <Label fx:id="signUpMessage" text="" wrapText="true"
                           style="-fx-font-size: 13px; -fx-font-weight: bold;"/>

                    <Button text="Create Account →" prefWidth="370" prefHeight="45"
                            style="-fx-background-color: #FACC15; -fx-text-fill: black;
                                   -fx-font-weight: bold; -fx-font-size: 15px;
                                   -fx-background-radius: 12; -fx-cursor: hand;"
                            onAction="#handleSignUp"/>

                    <!-- Divider -->
                    <HBox alignment="CENTER" spacing="10">
                        <Separator HBox.hgrow="ALWAYS"/>
                        <Label text="or sign up with"
                               style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF;"/>
                        <Separator HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <!-- Alternative signup buttons -->
                    <HBox spacing="10" alignment="CENTER">
                        <Button text="🌐  Sign up with Google"
                                prefWidth="370" prefHeight="42"
                                style="-fx-background-color: white; -fx-text-fill: #374151;
                                       -fx-border-color: #D1D5DB; -fx-border-radius: 10;
                                       -fx-background-radius: 10; -fx-font-size: 13px;
                                       -fx-cursor: hand; -fx-font-weight: bold;"
                                onAction="#handleGoogleSignIn"/>
                    </HBox>
                </VBox>

            </VBox>
        </VBox>
    </ScrollPane>
</StackPane>
