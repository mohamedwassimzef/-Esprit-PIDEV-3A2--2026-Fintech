<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="740.0" prefWidth="1000.0" stylesheets="@styles.css"
      xmlns="http://javafx.com/javafx/22"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.AdminDashboardController">
    <children>

        <!-- ── Menu Bar ─────────────────────────────────────────── -->
        <MenuBar VBox.vgrow="NEVER">
            <menus>
                <Menu mnemonicParsing="false" text="File">
                    <items>
                        <MenuItem mnemonicParsing="false" text="Logout" onAction="#handleLogout"/>
                        <SeparatorMenuItem mnemonicParsing="false"/>
                        <MenuItem mnemonicParsing="false" text="Quit" onAction="#handleQuit"/>
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Help">
                    <items>
                        <MenuItem mnemonicParsing="false" text="About"/>
                    </items>
                </Menu>
            </menus>
        </MenuBar>

        <!-- Welcome banner + Logout button -->
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color:#1a1a1a;-fx-padding:6 16 6 16;-fx-border-color:#2a2a2a;-fx-border-width:0 0 1 0;">
            <children>
                <Label fx:id="welcomeLabel" text="Welcome, Admin"
                       style="-fx-text-fill:#f5c800;-fx-font-size:13px;-fx-font-weight:700;-fx-letter-spacing:0.5;"
                       HBox.hgrow="ALWAYS"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Logout"
                        mnemonicParsing="false"
                        onAction="#handleLogout"
                        style="-fx-background-color:transparent;-fx-border-color:#f5c800;-fx-border-width:1;-fx-border-radius:4;-fx-text-fill:#f5c800;-fx-font-size:11px;-fx-font-weight:700;-fx-padding:4 14 4 14;-fx-cursor:hand;"/>
            </children>
        </HBox>

        <!-- ── Tab Pane ──────────────────────────────────────────── -->
        <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
            <tabs>

                <!-- ═══════════════════════════════════════════════
                     TAB 1 – CONTRACT REQUESTS (approve / reject)
                ═══════════════════════════════════════════════ -->
                <Tab text="Contract Requests">
                    <content>
                        <AnchorPane>
                            <children>
                                <!-- Stats bar -->
                                <HBox spacing="20.0"
                                      AnchorPane.topAnchor="12.0"
                                      AnchorPane.leftAnchor="20.0"
                                      AnchorPane.rightAnchor="20.0">
                                    <children>
                                        <Label fx:id="pendingCountLabel"
                                               text="PENDING: 0"
                                               style="-fx-text-fill:#f5c800;-fx-font-weight:800;-fx-font-size:11px;-fx-letter-spacing:1.0;-fx-padding:4 0 0 0;"/>
                                        <Label fx:id="approvedCountLabel"
                                               text="APPROVED: 0"
                                               style="-fx-text-fill:#22cc66;-fx-font-weight:800;-fx-font-size:11px;-fx-letter-spacing:1.0;-fx-padding:4 0 0 0;"/>
                                        <Label fx:id="rejectedCountLabel"
                                               text="REJECTED: 0"
                                               style="-fx-text-fill:#cc2200;-fx-font-weight:800;-fx-font-size:11px;-fx-letter-spacing:1.0;-fx-padding:4 0 0 0;"/>
                                        <Label fx:id="signedCountLabel"
                                               text="SIGNED: 0"
                                               style="-fx-text-fill:#00ccff;-fx-font-weight:800;-fx-font-size:11px;-fx-letter-spacing:1.0;-fx-padding:4 0 0 0;"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <ComboBox fx:id="requestStatusFilter" promptText="All Statuses"
                                                  onAction="#handleRequestStatusFilter" prefWidth="160.0"/>
                                    </children>
                                </HBox>

                                <TableView fx:id="requestsTable"
                                           AnchorPane.topAnchor="50.0"
                                           AnchorPane.leftAnchor="20.0"
                                           AnchorPane.rightAnchor="20.0"
                                           AnchorPane.bottomAnchor="60.0">
                                    <columns>
                                        <TableColumn fx:id="reqColId"        text="ID"        prefWidth="50.0" visible="false"/>
                                        <TableColumn fx:id="reqColUserId"    text="User ID"   prefWidth="80.0"/>
                                        <TableColumn fx:id="reqColAssetId"   text="Asset ID"  prefWidth="80.0"/>
                                        <TableColumn fx:id="reqColPackageId" text="Package"   prefWidth="80.0"/>
                                        <TableColumn fx:id="reqColPremium"   text="Premium"   prefWidth="100.0"/>
                                        <TableColumn fx:id="reqColStatus"    text="Status"    prefWidth="100.0"/>
                                        <TableColumn fx:id="reqColCreatedAt" text="Submitted" prefWidth="140.0"/>
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                    </columnResizePolicy>
                                </TableView>

                                <HBox spacing="12.0"
                                      AnchorPane.bottomAnchor="12.0"
                                      AnchorPane.leftAnchor="20.0"
                                      AnchorPane.rightAnchor="20.0">
                                    <children>
                                        <Button fx:id="approveBtn" text="APPROVE"
                                                disable="true"
                                                mnemonicParsing="false"
                                                onAction="#handleApproveRequest"
                                                prefWidth="200.0"
                                                styleClass="btn-approve"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Button fx:id="rejectBtn" text="REJECT"
                                                disable="true"
                                                mnemonicParsing="false"
                                                onAction="#handleRejectRequest"
                                                prefWidth="200.0"
                                                styleClass="btn-reject"/>
                                    </children>
                                </HBox>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>

                <!-- ═══════════════════════════════════════════════
                     TAB 2 – MANAGE PACKAGES (full CRUD)
                ═══════════════════════════════════════════════ -->
                <Tab text="Manage Packages">
                    <content>
                        <HBox spacing="0.0">

                            <!-- LEFT: form panel wrapped in ScrollPane -->
                            <ScrollPane prefWidth="340.0" minWidth="340.0" maxWidth="340.0"
                                        fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                        style="-fx-background:transparent;-fx-background-color:transparent;-fx-border-color:transparent;">
                                <content>
                                    <VBox styleClass="form-container" spacing="2.0"
                                          style="-fx-padding:24 24 24 24;">
                                        <children>
                                            <Label text="PACKAGE NAME"/>
                                            <TextField fx:id="pkgName" promptText="e.g. Basic Car Cover"/>

                                            <Label text="ASSET TYPE"/>
                                            <ComboBox fx:id="pkgAssetType" maxWidth="Infinity" promptText="car / home / land"/>

                                            <Label text="BASE PRICE (TND)"/>
                                            <TextField fx:id="pkgBasePrice" promptText="0.00"/>

                                            <Label text="RISK MULTIPLIER"/>
                                            <TextField fx:id="pkgRiskMultiplier" promptText="1.0"/>

                                            <Label text="DURATION (months)"/>
                                            <TextField fx:id="pkgDurationMonths" promptText="12"/>

                                            <Label text="DESCRIPTION"/>
                                            <TextArea fx:id="pkgDescription" promptText="Package description..."
                                                      prefHeight="60.0" wrapText="true"/>

                                            <Label text="COVERAGE DETAILS"/>
                                            <TextArea fx:id="pkgCoverageDetails" promptText="What is covered..."
                                                      prefHeight="60.0" wrapText="true"/>

                                            <CheckBox fx:id="pkgIsActive" text="Active" selected="true"
                                                      style="-fx-text-fill:#f0f0f0;"/>

                                            <Region prefHeight="10.0"/>

                                            <Button fx:id="pkgSubmitBtn" text="Add Package"
                                                    mnemonicParsing="false"
                                                    onAction="#handlePackageSubmit"
                                                    maxWidth="Infinity"/>

                                            <Button fx:id="pkgClearBtn" text="Clear Form"
                                                    mnemonicParsing="false"
                                                    onAction="#handlePackageClear"
                                                    maxWidth="Infinity"
                                                    style="-fx-background-color:transparent;-fx-border-color:#f5c800;-fx-text-fill:#f5c800;-fx-border-width:1;"/>
                                        </children>
                                    </VBox>
                                </content>
                            </ScrollPane>

                            <!-- RIGHT: packages table -->
                            <AnchorPane HBox.hgrow="ALWAYS">
                                <children>
                                    <TableView fx:id="adminPackagesTable"
                                               AnchorPane.topAnchor="16.0"
                                               AnchorPane.leftAnchor="12.0"
                                               AnchorPane.rightAnchor="12.0"
                                               AnchorPane.bottomAnchor="60.0">
                                        <columns>
                                            <TableColumn fx:id="apkgColId"       text="ID"       prefWidth="50.0" visible="false"/>
                                            <TableColumn fx:id="apkgColName"     text="Name"     prefWidth="160.0"/>
                                            <TableColumn fx:id="apkgColType"     text="Type"     prefWidth="70.0"/>
                                            <TableColumn fx:id="apkgColPrice"    text="Price"    prefWidth="90.0"/>
                                            <TableColumn fx:id="apkgColRisk"     text="Risk x"   prefWidth="65.0"/>
                                            <TableColumn fx:id="apkgColDuration" text="Duration" prefWidth="70.0"/>
                                            <TableColumn fx:id="apkgColActive"   text="Active"   prefWidth="60.0"/>
                                        </columns>
                                        <columnResizePolicy>
                                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                        </columnResizePolicy>
                                    </TableView>

                                    <HBox spacing="12.0"
                                          AnchorPane.bottomAnchor="12.0"
                                          AnchorPane.leftAnchor="12.0"
                                          AnchorPane.rightAnchor="12.0">
                                        <children>
                                            <Button fx:id="pkgUpdateBtn" text="Edit Selected"
                                                    disable="true" mnemonicParsing="false"
                                                    onAction="#handlePackageEdit"
                                                    prefWidth="180.0"/>
                                            <Region HBox.hgrow="ALWAYS"/>
                                            <Button fx:id="pkgDeleteBtn" text="Delete Selected"
                                                    disable="true" mnemonicParsing="false"
                                                    onAction="#handlePackageDelete"
                                                    prefWidth="180.0"/>
                                        </children>
                                    </HBox>
                                </children>
                            </AnchorPane>

                        </HBox>
                    </content>
                </Tab>

                <!-- ═══════════════════════════════════════════════
                     TAB 3 – ALL ASSETS (read-only overview)
                ═══════════════════════════════════════════════ -->
                <Tab text="All Assets">
                    <content>
                        <AnchorPane>
                            <children>
                                <TableView fx:id="allAssetsTable"
                                           AnchorPane.topAnchor="20.0"
                                           AnchorPane.leftAnchor="20.0"
                                           AnchorPane.rightAnchor="20.0"
                                           AnchorPane.bottomAnchor="20.0">
                                    <columns>
                                        <TableColumn fx:id="aColId"          text="ID"          prefWidth="50.0" visible="false"/>
                                        <TableColumn fx:id="aColUserId"      text="User ID"     prefWidth="80.0"/>
                                        <TableColumn fx:id="aColName"        text="Name"        prefWidth="160.0"/>
                                        <TableColumn fx:id="aColType"        text="Type"        prefWidth="90.0"/>
                                        <TableColumn fx:id="aColValue"       text="Value"       prefWidth="100.0"/>
                                        <TableColumn fx:id="aColDescription" text="Description" prefWidth="180.0"/>
                                        <TableColumn fx:id="aColLocation"    text="Location"    prefWidth="140.0"/>
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>

            </tabs>
        </TabPane>

    </children>
</VBox>





