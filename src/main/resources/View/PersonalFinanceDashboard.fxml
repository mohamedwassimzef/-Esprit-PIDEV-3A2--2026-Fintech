<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="740.0" prefWidth="1100.0"
            stylesheets="@styles.css"
            xmlns="http://javafx.com/javafx/22"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.PersonalFinanceController">

    <!-- TOP BAR -->
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
            <Label text="FinTech" styleClass="topbar-brand"/>
            <Label text="/ Personal Finance" styleClass="topbar-module"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" text="Welcome, User" styleClass="topbar-welcome"/>
            <Button text="Logout" styleClass="btn-outline-gold"
                    mnemonicParsing="false" onAction="#handleLogout"/>
        </HBox>
    </top>

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" prefWidth="185.0" spacing="4">
            <Label text="SERVICES" styleClass="sidebar-section-label"/>
            <Button text="Shield  Insurance" styleClass="sidebar-btn"
                    mnemonicParsing="false" maxWidth="Infinity" onAction="#goInsurance"/>
            <Button text="Personal Finance" styleClass="sidebar-btn sidebar-btn-active"
                    mnemonicParsing="false" maxWidth="Infinity"/>
            <Button text="Loans" styleClass="sidebar-btn"
                    mnemonicParsing="false" maxWidth="Infinity" onAction="#goLoans"/>
            <Button text="Transactions" styleClass="sidebar-btn"
                    mnemonicParsing="false" maxWidth="Infinity" onAction="#goTransactions"/>
            <Label text="COMING SOON" styleClass="sidebar-section-label" style="-fx-padding:18 0 4 0;"/>
            <Button text="Transactions"     styleClass="sidebar-btn sidebar-btn-disabled" mnemonicParsing="false" maxWidth="Infinity" disable="true"/>
            <Button text="Complaints"       styleClass="sidebar-btn sidebar-btn-disabled" mnemonicParsing="false" maxWidth="Infinity" disable="true"/>
            <Button text="Loans"            styleClass="sidebar-btn sidebar-btn-disabled" mnemonicParsing="false" maxWidth="Infinity" disable="true"/>
            <Button text="Statistics"       styleClass="sidebar-btn sidebar-btn-disabled" mnemonicParsing="false" maxWidth="Infinity" disable="true"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="Back to Home" styleClass="sidebar-btn"
                    mnemonicParsing="false" maxWidth="Infinity" onAction="#handleBackHome"/>
        </VBox>
    </left>

    <!-- CENTER -->
    <center>
        <TabPane fx:id="mainTabs" tabClosingPolicy="UNAVAILABLE">
            <tabs>

                <!-- ═══════════════════════════
                     TAB 1 – MY BUDGETS
                ═══════════════════════════ -->
                <Tab fx:id="budgetListTab" text="My Budgets">
                    <content>
                        <AnchorPane>
                            <children>

                                <!-- Summary strip -->
                                <HBox fx:id="summaryStrip" spacing="16"
                                      AnchorPane.topAnchor="12" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20"
                                      style="-fx-padding:14 18 14 18;-fx-background-color:#1a1a1a;-fx-border-color:#2a2a2a;-fx-border-radius:6;-fx-background-radius:6;">
                                    <VBox alignment="CENTER" spacing="2" HBox.hgrow="ALWAYS">
                                        <Label text="TOTAL BUDGETED" styleClass="stat-label"/>
                                        <Label fx:id="totalBudgetedLabel" text="0.00 TND" styleClass="stat-value"/>
                                    </VBox>
                                    <Region style="-fx-background-color:#2a2a2a;" prefWidth="1" prefHeight="40"/>
                                    <VBox alignment="CENTER" spacing="2" HBox.hgrow="ALWAYS">
                                        <Label text="TOTAL SPENT" styleClass="stat-label"/>
                                        <Label fx:id="totalSpentLabel" text="0.00 TND" styleClass="stat-value-danger"/>
                                    </VBox>
                                    <Region style="-fx-background-color:#2a2a2a;" prefWidth="1" prefHeight="40"/>
                                    <VBox alignment="CENTER" spacing="2" HBox.hgrow="ALWAYS">
                                        <Label text="REMAINING" styleClass="stat-label"/>
                                        <Label fx:id="remainingLabel" text="0.00 TND" styleClass="stat-value-success"/>
                                    </VBox>
                                </HBox>

                                <!-- Budget table -->
                                <TableView fx:id="budgetTable"
                                           AnchorPane.topAnchor="90" AnchorPane.leftAnchor="20"
                                           AnchorPane.rightAnchor="20" AnchorPane.bottomAnchor="60">
                                    <columns>
                                        <TableColumn fx:id="bColId"          text="ID"         prefWidth="50"  visible="false"/>
                                        <TableColumn fx:id="bColName"        text="Budget Name" prefWidth="160"/>
                                        <TableColumn fx:id="bColCategory"    text="Category"   prefWidth="110"/>
                                        <TableColumn fx:id="bColAmount"      text="Amount"     prefWidth="100"/>
                                        <TableColumn fx:id="bColSpent"       text="Spent"      prefWidth="100"/>
                                        <TableColumn fx:id="bColRemaining"   text="Remaining"  prefWidth="100"/>
                                        <TableColumn fx:id="bColProgress"    text="Usage"      prefWidth="130"/>
                                        <TableColumn fx:id="bColStartDate"   text="Start"      prefWidth="90"/>
                                        <TableColumn fx:id="bColEndDate"     text="End"        prefWidth="90"/>
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                    </columnResizePolicy>
                                </TableView>

                                <!-- Action bar -->
                                <HBox spacing="10" AnchorPane.bottomAnchor="12"
                                      AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20">
                                    <Button text="+" mnemonicParsing="false" onAction="#handleAddBudget"
                                            prefWidth="40"
                                            style="-fx-font-size:18px;-fx-font-weight:900;-fx-background-color:#f5c800;-fx-text-fill:#000;-fx-background-radius:5;-fx-cursor:hand;"/>
                                    <Button fx:id="updateBudgetBtn" text="Update" prefWidth="140"
                                            mnemonicParsing="false" onAction="#handleUpdateBudget" disable="true"/>
                                    <Button fx:id="viewExpensesBtn" text="View Expenses" prefWidth="160"
                                            mnemonicParsing="false" onAction="#handleViewExpenses"
                                            style="-fx-background-color:transparent;-fx-border-color:#f5c800;-fx-border-width:1;-fx-text-fill:#f5c800;-fx-border-radius:4;"
                                            disable="true"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button fx:id="deleteBudgetBtn" text="Delete" prefWidth="140"
                                            mnemonicParsing="false" onAction="#handleDeleteBudget" disable="true"/>
                                </HBox>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>

                <!-- ═══════════════════════════
                     TAB 2 – BUDGET FORM
                ═══════════════════════════ -->
                <Tab fx:id="budgetFormTab" text="Budget Form"
                     style="-fx-pref-width:0;-fx-min-width:0;-fx-max-width:0;-fx-opacity:0;">
                    <content>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    style="-fx-background:transparent;-fx-background-color:transparent;">
                            <content>
                                <VBox alignment="CENTER" style="-fx-padding:30 60 30 60;">
                                    <VBox styleClass="form-container" maxWidth="440" spacing="2">
                                        <Label fx:id="budgetFormTitle" text="NEW BUDGET"
                                               style="-fx-text-fill:#f5c800;-fx-font-size:14px;-fx-font-weight:900;-fx-padding:0 0 8 0;"/>

                                        <Label text="BUDGET NAME"/>
                                        <TextField fx:id="bName" promptText="e.g. Monthly Food"/>

                                        <Label text="CATEGORY"/>
                                        <ComboBox fx:id="bCategory" maxWidth="Infinity" promptText="Select category"/>

                                        <Label text="AMOUNT (TND)"/>
                                        <TextField fx:id="bAmount" promptText="0.00"/>

                                        <HBox spacing="16">
                                            <VBox HBox.hgrow="ALWAYS" spacing="2">
                                                <Label text="START DATE"/>
                                                <DatePicker fx:id="bStartDate" maxWidth="Infinity"/>
                                            </VBox>
                                            <VBox HBox.hgrow="ALWAYS" spacing="2">
                                                <Label text="END DATE"/>
                                                <DatePicker fx:id="bEndDate" maxWidth="Infinity"/>
                                            </VBox>
                                        </HBox>

                                        <Region prefHeight="12"/>
                                        <Button fx:id="submitBudgetBtn" text="Save Budget"
                                                mnemonicParsing="false" onAction="#handleSubmitBudget"
                                                maxWidth="Infinity"/>
                                        <Button text="Cancel" mnemonicParsing="false"
                                                onAction="#handleCancelBudgetForm" maxWidth="Infinity"
                                                style="-fx-background-color:transparent;-fx-border-color:#555;-fx-text-fill:#aaa;-fx-border-width:1;-fx-border-radius:4;"/>
                                    </VBox>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>

                <!-- ═══════════════════════════
                     TAB 3 – EXPENSES
                ═══════════════════════════ -->
                <Tab fx:id="expenseListTab" text="Expenses">
                    <content>
                        <AnchorPane>
                            <children>
                                <!-- Budget filter bar -->
                                <HBox spacing="12" alignment="CENTER_LEFT"
                                      AnchorPane.topAnchor="12" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20"
                                      style="-fx-padding:10 16 10 16;-fx-background-color:#1a1a1a;-fx-border-color:#2a2a2a;-fx-border-radius:6;-fx-background-radius:6;">
                                    <Label text="FILTER BY BUDGET:" styleClass="stat-label"/>
                                    <ComboBox fx:id="expenseBudgetFilter" promptText="All budgets"
                                              onAction="#handleBudgetFilterChange" prefWidth="220"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label text="TOTAL:" styleClass="stat-label"/>
                                    <Label fx:id="expenseTotalLabel" text="0.00 TND"
                                           style="-fx-text-fill:#f5c800;-fx-font-size:14px;-fx-font-weight:900;"/>
                                </HBox>

                                <!-- Expense table -->
                                <TableView fx:id="expenseTable"
                                           AnchorPane.topAnchor="72" AnchorPane.leftAnchor="20"
                                           AnchorPane.rightAnchor="20" AnchorPane.bottomAnchor="60">
                                    <columns>
                                        <TableColumn fx:id="eColId"          text="ID"          prefWidth="50"  visible="false"/>
                                        <TableColumn fx:id="eColDescription" text="Description" prefWidth="180"/>
                                        <TableColumn fx:id="eColCategory"    text="Category"    prefWidth="110"/>
                                        <TableColumn fx:id="eColAmount"      text="Amount"      prefWidth="100"/>
                                        <TableColumn fx:id="eColDate"        text="Date"        prefWidth="100"/>
                                        <TableColumn fx:id="eColBudget"      text="Budget"      prefWidth="130"/>
                                        <TableColumn fx:id="eColCreatedAt"   text="Recorded"    prefWidth="130"/>
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                    </columnResizePolicy>
                                </TableView>

                                <!-- Action bar -->
                                <HBox spacing="10" AnchorPane.bottomAnchor="12"
                                      AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20">
                                    <Button text="+" mnemonicParsing="false" onAction="#handleAddExpense"
                                            prefWidth="40"
                                            style="-fx-font-size:18px;-fx-font-weight:900;-fx-background-color:#f5c800;-fx-text-fill:#000;-fx-background-radius:5;-fx-cursor:hand;"/>
                                    <Button fx:id="updateExpenseBtn" text="Update" prefWidth="140"
                                            mnemonicParsing="false" onAction="#handleUpdateExpense" disable="true"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button fx:id="deleteExpenseBtn" text="Delete" prefWidth="140"
                                            mnemonicParsing="false" onAction="#handleDeleteExpense" disable="true"/>
                                </HBox>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>

                <!-- ═══════════════════════════
                     TAB 4 – EXPENSE FORM
                ═══════════════════════════ -->
                <Tab fx:id="expenseFormTab" text="Expense Form"
                     style="-fx-pref-width:0;-fx-min-width:0;-fx-max-width:0;-fx-opacity:0;">
                    <content>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    style="-fx-background:transparent;-fx-background-color:transparent;">
                            <content>
                                <VBox alignment="CENTER" style="-fx-padding:30 60 30 60;">
                                    <VBox styleClass="form-container" maxWidth="440" spacing="2">
                                        <Label fx:id="expenseFormTitle" text="NEW EXPENSE"
                                               style="-fx-text-fill:#f5c800;-fx-font-size:14px;-fx-font-weight:900;-fx-padding:0 0 8 0;"/>

                                        <Label text="DESCRIPTION"/>
                                        <TextField fx:id="eDescription" promptText="What was this expense for?"/>

                                        <Label text="CATEGORY"/>
                                        <ComboBox fx:id="eCategory" maxWidth="Infinity" promptText="Select category"/>

                                        <Label text="AMOUNT (TND)"/>
                                        <TextField fx:id="eAmount" promptText="0.00"/>

                                        <Label text="DATE"/>
                                        <DatePicker fx:id="eDate" maxWidth="Infinity"/>

                                        <Label text="BUDGET (optional)"/>
                                        <ComboBox fx:id="eBudgetCombo" maxWidth="Infinity" promptText="Link to a budget"/>

                                        <Region prefHeight="12"/>
                                        <Button fx:id="submitExpenseBtn" text="Save Expense"
                                                mnemonicParsing="false" onAction="#handleSubmitExpense"
                                                maxWidth="Infinity"/>
                                        <Button text="Cancel" mnemonicParsing="false"
                                                onAction="#handleCancelExpenseForm" maxWidth="Infinity"
                                                style="-fx-background-color:transparent;-fx-border-color:#555;-fx-text-fill:#aaa;-fx-border-width:1;-fx-border-radius:4;"/>
                                    </VBox>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>

            </tabs>
        </TabPane>
    </center>

</BorderPane>



