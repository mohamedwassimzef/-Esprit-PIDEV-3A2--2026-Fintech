<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="740.0" prefWidth="1100.0"
            stylesheets="@styles.css"
            xmlns="http://javafx.com/javafx/22"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.LoanController">

    <!-- TOP BAR -->
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
            <Label text="FinTech" styleClass="topbar-brand"/>
            <Label text="/ Loans" styleClass="topbar-module"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" text="Welcome, User" styleClass="topbar-welcome"/>
            <Button text="Logout" styleClass="btn-outline-gold"
                    mnemonicParsing="false" onAction="#handleLogout"/>
        </HBox>
    </top>

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" prefWidth="185.0" spacing="4">
            <Label text="SERVICES" styleClass="sidebar-section-label"/>
            <Button text="Insurance"        styleClass="sidebar-btn" mnemonicParsing="false" maxWidth="Infinity" onAction="#goInsurance"/>
            <Button text="Personal Finance" styleClass="sidebar-btn" mnemonicParsing="false" maxWidth="Infinity" onAction="#goPersonalFinance"/>
            <Button text="Loans"            styleClass="sidebar-btn sidebar-btn-active" mnemonicParsing="false" maxWidth="Infinity"/>
            <Button text="Transactions"     styleClass="sidebar-btn" mnemonicParsing="false" maxWidth="Infinity" onAction="#goTransactions"/>
            <Label text="COMING SOON" styleClass="sidebar-section-label" style="-fx-padding:18 0 4 0;"/>
            <Button text="Transactions" styleClass="sidebar-btn sidebar-btn-disabled" mnemonicParsing="false" maxWidth="Infinity" disable="true"/>
            <Button text="Complaints"   styleClass="sidebar-btn sidebar-btn-disabled" mnemonicParsing="false" maxWidth="Infinity" disable="true"/>
            <Button text="Statistics"   styleClass="sidebar-btn sidebar-btn-disabled" mnemonicParsing="false" maxWidth="Infinity" disable="true"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="Back to Home" styleClass="sidebar-btn" mnemonicParsing="false" maxWidth="Infinity" onAction="#handleBackHome"/>
        </VBox>
    </left>

    <!-- CENTER -->
    <center>
        <TabPane fx:id="mainTabs" tabClosingPolicy="UNAVAILABLE">
            <tabs>

                <!-- ═══════════════════════ TAB 1 – MY LOANS ═══════════════════════ -->
                <Tab fx:id="loanListTab" text="My Loans">
                    <content>
                        <AnchorPane>
                            <children>

                                <!-- Summary strip -->
                                <HBox spacing="16" AnchorPane.topAnchor="12"
                                      AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20"
                                      style="-fx-padding:14 18 14 18;-fx-background-color:#1a1a1a;-fx-border-color:#2a2a2a;-fx-border-radius:6;-fx-background-radius:6;">
                                    <VBox alignment="CENTER" spacing="2" HBox.hgrow="ALWAYS">
                                        <Label text="TOTAL BORROWED" styleClass="stat-label"/>
                                        <Label fx:id="totalBorrowedLabel" text="0.00 TND" styleClass="stat-value"/>
                                    </VBox>
                                    <Region style="-fx-background-color:#2a2a2a;" prefWidth="1" prefHeight="40"/>
                                    <VBox alignment="CENTER" spacing="2" HBox.hgrow="ALWAYS">
                                        <Label text="TOTAL REPAID" styleClass="stat-label"/>
                                        <Label fx:id="totalRepaidLabel" text="0.00 TND" styleClass="stat-value-success"/>
                                    </VBox>
                                    <Region style="-fx-background-color:#2a2a2a;" prefWidth="1" prefHeight="40"/>
                                    <VBox alignment="CENTER" spacing="2" HBox.hgrow="ALWAYS">
                                        <Label text="OUTSTANDING" styleClass="stat-label"/>
                                        <Label fx:id="outstandingLabel" text="0.00 TND" styleClass="stat-value-danger"/>
                                    </VBox>
                                    <Region style="-fx-background-color:#2a2a2a;" prefWidth="1" prefHeight="40"/>
                                    <VBox alignment="CENTER" spacing="2" HBox.hgrow="ALWAYS">
                                        <Label text="ACTIVE LOANS" styleClass="stat-label"/>
                                        <Label fx:id="activeLoansLabel" text="0" styleClass="stat-value"/>
                                    </VBox>
                                </HBox>

                                <!-- Loan table -->
                                <TableView fx:id="loanTable"
                                           AnchorPane.topAnchor="90" AnchorPane.leftAnchor="20"
                                           AnchorPane.rightAnchor="20" AnchorPane.bottomAnchor="60">
                                    <columns>
                                        <TableColumn fx:id="lColId"           text="ID"           prefWidth="50"  visible="false"/>
                                        <TableColumn fx:id="lColAmount"       text="Amount"       prefWidth="110"/>
                                        <TableColumn fx:id="lColInterestRate" text="Rate %"       prefWidth="80"/>
                                        <TableColumn fx:id="lColMonthly"      text="Monthly PMT"  prefWidth="110"/>
                                        <TableColumn fx:id="lColTotalCost"    text="Total Cost"   prefWidth="110"/>
                                        <TableColumn fx:id="lColStatus"       text="Status"       prefWidth="90"/>
                                        <TableColumn fx:id="lColStartDate"    text="Start"        prefWidth="95"/>
                                        <TableColumn fx:id="lColEndDate"      text="End"          prefWidth="95"/>
                                        <TableColumn fx:id="lColCreatedAt"    text="Created"      prefWidth="130"/>
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                    </columnResizePolicy>
                                </TableView>

                                <!-- Action bar -->
                                <HBox spacing="10" AnchorPane.bottomAnchor="12"
                                      AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20">
                                    <Button text="+" mnemonicParsing="false" onAction="#handleAddLoan"
                                            prefWidth="40"
                                            style="-fx-font-size:18px;-fx-font-weight:900;-fx-background-color:#f5c800;-fx-text-fill:#000;-fx-background-radius:5;-fx-cursor:hand;"/>
                                    <Button fx:id="updateLoanBtn" text="Update" prefWidth="130"
                                            mnemonicParsing="false" onAction="#handleUpdateLoan" disable="true"/>
                                    <Button fx:id="viewRepaymentsBtn" text="View Repayments" prefWidth="160"
                                            mnemonicParsing="false" onAction="#handleViewRepayments"
                                            style="-fx-background-color:transparent;-fx-border-color:#f5c800;-fx-border-width:1;-fx-text-fill:#f5c800;-fx-border-radius:4;"
                                            disable="true"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button fx:id="deleteLoanBtn" text="Delete" prefWidth="130"
                                            mnemonicParsing="false" onAction="#handleDeleteLoan" disable="true"/>
                                </HBox>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>

                <!-- ═══════════════════════ TAB 2 – LOAN FORM ═══════════════════════ -->
                <Tab fx:id="loanFormTab" text="Loan Form"
                     style="-fx-pref-width:0;-fx-min-width:0;-fx-max-width:0;-fx-opacity:0;">
                    <content>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    style="-fx-background:transparent;-fx-background-color:transparent;">
                            <content>
                                <VBox alignment="CENTER" style="-fx-padding:30 60 30 60;">
                                    <VBox styleClass="form-container" maxWidth="480" spacing="2">
                                        <Label fx:id="loanFormTitle" text="NEW LOAN"
                                               style="-fx-text-fill:#f5c800;-fx-font-size:14px;-fx-font-weight:900;-fx-padding:0 0 8 0;"/>

                                        <Label text="LOAN AMOUNT (TND)"/>
                                        <TextField fx:id="lAmount" promptText="e.g. 10000.00"/>

                                        <Label text="INTEREST RATE (% per year)"/>
                                        <TextField fx:id="lInterestRate" promptText="e.g. 5.5"/>

                                        <HBox spacing="16">
                                            <VBox HBox.hgrow="ALWAYS" spacing="2">
                                                <Label text="START DATE"/>
                                                <DatePicker fx:id="lStartDate" maxWidth="Infinity" onAction="#handleLoanDateChange"/>
                                            </VBox>
                                            <VBox HBox.hgrow="ALWAYS" spacing="2">
                                                <Label text="END DATE"/>
                                                <DatePicker fx:id="lEndDate" maxWidth="Infinity" onAction="#handleLoanDateChange"/>
                                            </VBox>
                                        </HBox>

                                        <Label text="STATUS"/>
                                        <ComboBox fx:id="lStatus" maxWidth="Infinity" promptText="Select status"/>

                                        <!-- Auto-calculated summary -->
                                        <VBox style="-fx-background-color:#1a1a1a;-fx-border-color:#2a2a2a;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:14 16 14 16;-fx-spacing:6;" spacing="4">
                                            <Label text="LOAN SUMMARY" style="-fx-text-fill:#555;-fx-font-size:9px;-fx-font-weight:900;-fx-letter-spacing:1.2;"/>
                                            <HBox spacing="8">
                                                <Label text="Duration:" style="-fx-text-fill:#888;-fx-font-size:12px;" HBox.hgrow="ALWAYS"/>
                                                <Label fx:id="calcDuration" text="—" style="-fx-text-fill:#f5c800;-fx-font-weight:700;"/>
                                            </HBox>
                                            <HBox spacing="8">
                                                <Label text="Monthly Payment:" style="-fx-text-fill:#888;-fx-font-size:12px;" HBox.hgrow="ALWAYS"/>
                                                <Label fx:id="calcMonthly" text="—" style="-fx-text-fill:#f5c800;-fx-font-weight:700;"/>
                                            </HBox>
                                            <HBox spacing="8">
                                                <Label text="Total Interest:" style="-fx-text-fill:#888;-fx-font-size:12px;" HBox.hgrow="ALWAYS"/>
                                                <Label fx:id="calcInterest" text="—" style="-fx-text-fill:#ff8844;-fx-font-weight:700;"/>
                                            </HBox>
                                            <HBox spacing="8">
                                                <Label text="Total Cost:" style="-fx-text-fill:#888;-fx-font-size:12px;" HBox.hgrow="ALWAYS"/>
                                                <Label fx:id="calcTotal" text="—" style="-fx-text-fill:#33dd77;-fx-font-weight:700;"/>
                                            </HBox>
                                        </VBox>

                                        <Region prefHeight="8"/>
                                        <Button fx:id="submitLoanBtn" text="Apply for Loan"
                                                mnemonicParsing="false" onAction="#handleSubmitLoan"
                                                maxWidth="Infinity"/>
                                        <Button text="Cancel" mnemonicParsing="false"
                                                onAction="#handleCancelLoanForm" maxWidth="Infinity"
                                                style="-fx-background-color:transparent;-fx-border-color:#555;-fx-text-fill:#aaa;-fx-border-width:1;-fx-border-radius:4;"/>
                                    </VBox>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>

                <!-- ═══════════════════════ TAB 3 – REPAYMENTS ═══════════════════════ -->
                <Tab fx:id="repaymentListTab" text="Repayments">
                    <content>
                        <AnchorPane>
                            <children>
                                <!-- Loan filter bar -->
                                <HBox spacing="12" alignment="CENTER_LEFT"
                                      AnchorPane.topAnchor="12" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20"
                                      style="-fx-padding:10 16 10 16;-fx-background-color:#1a1a1a;-fx-border-color:#2a2a2a;-fx-border-radius:6;-fx-background-radius:6;">
                                    <Label text="FILTER BY LOAN:" styleClass="stat-label"/>
                                    <ComboBox fx:id="repaymentLoanFilter" promptText="All loans"
                                              onAction="#handleLoanFilterChange" prefWidth="240"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label text="TOTAL PAID:" styleClass="stat-label"/>
                                    <Label fx:id="repaymentTotalLabel" text="0.00 TND"
                                           style="-fx-text-fill:#33dd77;-fx-font-size:14px;-fx-font-weight:900;"/>
                                </HBox>

                                <!-- Repayment table -->
                                <TableView fx:id="repaymentTable"
                                           AnchorPane.topAnchor="72" AnchorPane.leftAnchor="20"
                                           AnchorPane.rightAnchor="20" AnchorPane.bottomAnchor="60">
                                    <columns>
                                        <TableColumn fx:id="rColId"          text="ID"          prefWidth="50"  visible="false"/>
                                        <TableColumn fx:id="rColLoan"        text="Loan"        prefWidth="160"/>
                                        <TableColumn fx:id="rColAmount"      text="Amount"      prefWidth="100"/>
                                        <TableColumn fx:id="rColMonthly"     text="Monthly"     prefWidth="100"/>
                                        <TableColumn fx:id="rColPaymentType" text="Type"        prefWidth="100"/>
                                        <TableColumn fx:id="rColStatus"      text="Status"      prefWidth="90"/>
                                        <TableColumn fx:id="rColDate"        text="Date"        prefWidth="100"/>
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                    </columnResizePolicy>
                                </TableView>

                                <!-- Action bar -->
                                <HBox spacing="10" AnchorPane.bottomAnchor="12"
                                      AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20">
                                    <Button text="+" mnemonicParsing="false" onAction="#handleAddRepayment"
                                            prefWidth="40"
                                            style="-fx-font-size:18px;-fx-font-weight:900;-fx-background-color:#f5c800;-fx-text-fill:#000;-fx-background-radius:5;-fx-cursor:hand;"/>
                                    <Button fx:id="updateRepaymentBtn" text="Update" prefWidth="130"
                                            mnemonicParsing="false" onAction="#handleUpdateRepayment" disable="true"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button fx:id="deleteRepaymentBtn" text="Delete" prefWidth="130"
                                            mnemonicParsing="false" onAction="#handleDeleteRepayment" disable="true"/>
                                </HBox>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>

                <!-- ═══════════════════════ TAB 4 – REPAYMENT FORM ═══════════════════════ -->
                <Tab fx:id="repaymentFormTab" text="Repayment Form"
                     style="-fx-pref-width:0;-fx-min-width:0;-fx-max-width:0;-fx-opacity:0;">
                    <content>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    style="-fx-background:transparent;-fx-background-color:transparent;">
                            <content>
                                <VBox alignment="CENTER" style="-fx-padding:30 60 30 60;">
                                    <VBox styleClass="form-container" maxWidth="440" spacing="2">
                                        <Label fx:id="repaymentFormTitle" text="NEW REPAYMENT"
                                               style="-fx-text-fill:#f5c800;-fx-font-size:14px;-fx-font-weight:900;-fx-padding:0 0 8 0;"/>

                                        <Label text="LOAN"/>
                                        <ComboBox fx:id="rLoanCombo" maxWidth="Infinity" promptText="Select loan"/>

                                        <Label text="AMOUNT (TND)"/>
                                        <TextField fx:id="rAmount" promptText="0.00"/>

                                        <Label text="MONTHLY PAYMENT (TND)"/>
                                        <TextField fx:id="rMonthlyPayment" promptText="auto-calculated"
                                                   editable="false"
                                                   style="-fx-background-color:#1a1a1a;-fx-text-fill:#f5c800;"/>

                                        <Label text="PAYMENT TYPE"/>
                                        <ComboBox fx:id="rPaymentType" maxWidth="Infinity" promptText="Select type"/>

                                        <Label text="PAYMENT STATUS"/>
                                        <ComboBox fx:id="rStatus" maxWidth="Infinity" promptText="Select status"/>

                                        <Label text="PAYMENT DATE"/>
                                        <DatePicker fx:id="rDate" maxWidth="Infinity"/>

                                        <Region prefHeight="12"/>
                                        <Button fx:id="submitRepaymentBtn" text="Save Repayment"
                                                mnemonicParsing="false" onAction="#handleSubmitRepayment"
                                                maxWidth="Infinity"/>
                                        <Button text="Cancel" mnemonicParsing="false"
                                                onAction="#handleCancelRepaymentForm" maxWidth="Infinity"
                                                style="-fx-background-color:transparent;-fx-border-color:#555;-fx-text-fill:#aaa;-fx-border-width:1;-fx-border-radius:4;"/>
                                    </VBox>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>

            </tabs>
        </TabPane>
    </center>

</BorderPane>


