<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            style="-fx-background-color:#080808;-fx-background:#080808;-fx-border-color:transparent;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.LoginController">
    <content>
        <VBox alignment="CENTER" minHeight="600.0" prefWidth="460.0"
              style="-fx-background-color:#080808;"
              stylesheets="@styles.css">
            <padding>
                <Insets top="40" right="60" bottom="40" left="60"/>
            </padding>
            <VBox styleClass="form-container" spacing="2.0" maxWidth="360.0">

                <!-- Logo / brand -->
                <Label text="FI"
                       style="-fx-text-fill:#f5c800;-fx-font-size:36px;-fx-font-weight:900;
                              -fx-background-color:#111100;-fx-border-color:#f5c800;
                              -fx-border-width:2;-fx-border-radius:8;-fx-background-radius:8;
                              -fx-padding:6 18 6 18;-fx-alignment:center;"/>
                <Region prefHeight="8.0"/>
                <Label text="FINTECH INSURANCE"
                       style="-fx-text-fill:#f5c800;-fx-font-size:17px;-fx-font-weight:900;-fx-letter-spacing:2.0;"/>
                <Label text="ASSET PROTECTION PORTAL"
                       style="-fx-text-fill:#333333;-fx-font-size:9px;-fx-font-weight:700;
                              -fx-letter-spacing:2.5;-fx-padding:0 0 12 0;"/>

                <!-- Dynamic title -->
                <Label fx:id="titleLabel" text="SIGN IN"
                       style="-fx-text-fill:#f0f0f0;-fx-font-size:13px;-fx-font-weight:800;
                              -fx-letter-spacing:1.5;-fx-padding:4 0 10 0;"/>

                <!-- Sign-Up only fields (hidden initially) -->
                <VBox fx:id="signupFields" spacing="2.0" visible="false" managed="false">
                    <Label text="FULL NAME"/>
                    <TextField fx:id="nameField" promptText="Enter your full name"/>
                    <Label text="PHONE (optional)"/>
                    <TextField fx:id="phoneField" promptText="e.g. 20000000"/>
                    <Region prefHeight="4.0"/>
                </VBox>

                <!-- Shared fields -->
                <Label text="EMAIL"/>
                <TextField fx:id="emailField" promptText="Enter your email"/>

                <Label text="PASSWORD"/>
                <!-- Password field with eye toggle -->
                <HBox spacing="4.0" alignment="CENTER_LEFT">
                    <PasswordField fx:id="passwordField" promptText="Enter your password" HBox.hgrow="ALWAYS"/>
                    <TextField    fx:id="passwordVisible" promptText="Enter your password" HBox.hgrow="ALWAYS"/>
                    <Button fx:id="togglePasswordBtn" text="&#128065;"
                            mnemonicParsing="false" onAction="#handleTogglePassword"
                            style="-fx-background-color:transparent;-fx-text-fill:#888;
                                   -fx-font-size:14px;-fx-padding:4 6 4 6;-fx-cursor:hand;
                                   -fx-border-color:transparent;"/>
                </HBox>

                <!-- Forgot password link -->
                <HBox alignment="CENTER_RIGHT">
                    <Button text="Forgot password?" mnemonicParsing="false"
                            onAction="#handleForgotPassword"
                            style="-fx-background-color:transparent;-fx-text-fill:#555;
                                   -fx-font-size:10px;-fx-padding:0;-fx-cursor:hand;
                                   -fx-border-color:transparent;"/>
                </HBox>

                <!-- Confirm password (sign-up only) -->
                <VBox fx:id="confirmPasswordBox" spacing="2.0" visible="false" managed="false">
                    <Label text="CONFIRM PASSWORD"/>
                    <PasswordField fx:id="confirmPasswordField" promptText="Repeat your password"/>
                </VBox>

                <Region prefHeight="6.0"/>

                <!-- Captcha opens as a popup when Sign In / Sign Up is clicked -->

                <Region prefHeight="4.0"/>

                <!-- Error / success message -->
                <Label fx:id="errorLabel" text=""
                       style="-fx-text-fill:#cc2200;-fx-font-size:11px;-fx-padding:0;"
                       wrapText="true"/>

                <Region prefHeight="8.0"/>

                <!-- Main action button -->
                <Button fx:id="loginButton" text="SIGN IN"
                        mnemonicParsing="false" onAction="#handleLogin"
                        maxWidth="Infinity"/>

                <Region prefHeight="14.0"/>

                <!-- Toggle sign-in / sign-up -->
                <HBox alignment="CENTER" spacing="4.0">
                    <Label fx:id="toggleLabel" text="Don't have an account?"
                           style="-fx-text-fill:#555555;-fx-font-size:11px;"/>
                    <Button fx:id="toggleButton" text="Sign Up"
                            mnemonicParsing="false" onAction="#handleToggle"
                            style="-fx-background-color:transparent;-fx-text-fill:#f5c800;
                                   -fx-font-size:11px;-fx-font-weight:700;-fx-padding:0;
                                   -fx-cursor:hand;-fx-border-color:transparent;"/>
                </HBox>

                <Region prefHeight="10.0"/>

                <Label text="Secure access  -  v2.0"
                       style="-fx-text-fill:#1e1e1e;-fx-font-size:9px;-fx-alignment:center;
                              -fx-padding:0;-fx-letter-spacing:1.0;"
                       maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
