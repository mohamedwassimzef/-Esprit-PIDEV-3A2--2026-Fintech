<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ScrollPane?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            style="-fx-background-color:#080808;-fx-background:#080808;-fx-border-color:transparent;"
            xmlns="http://javafx.com/javafx/22"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.ForgotPasswordController">
    <content>
        <VBox alignment="CENTER" minHeight="520.0" prefWidth="460.0"
              style="-fx-background-color:#080808;"
              stylesheets="@styles.css">
            <padding>
                <Insets top="60" right="60" bottom="60" left="60"/>
            </padding>
            <VBox styleClass="form-container" spacing="2.0" maxWidth="360.0">

                <!-- Logo -->
                <Label text="FI"
                       style="-fx-text-fill:#f5c800;-fx-font-size:36px;-fx-font-weight:900;
                              -fx-background-color:#111100;-fx-border-color:#f5c800;
                              -fx-border-width:2;-fx-border-radius:8;-fx-background-radius:8;
                              -fx-padding:6 18 6 18;-fx-alignment:center;"/>
                <Region prefHeight="8.0"/>

                <Label fx:id="titleLabel" text="FORGOT PASSWORD"
                       style="-fx-text-fill:#f5c800;-fx-font-size:17px;-fx-font-weight:900;-fx-letter-spacing:2.0;"/>
                <Label text="FINTECH INSURANCE PORTAL"
                       style="-fx-text-fill:#333;-fx-font-size:9px;-fx-font-weight:700;-fx-letter-spacing:2.5;-fx-padding:0 0 10 0;"/>

                <Label fx:id="infoLabel"
                       text="Enter your email and we'll send you a reset code."
                       wrapText="true"
                       style="-fx-text-fill:#888;-fx-font-size:12px;-fx-padding:0 0 8 0;"/>

                <!-- Step 1: email input -->
                <VBox fx:id="stepEmailBox" spacing="2.0">
                    <Label text="EMAIL"/>
                    <TextField fx:id="emailField" promptText="Enter your email"/>
                    <Region prefHeight="8.0"/>
                    <Button text="SEND CODE" mnemonicParsing="false" onAction="#handleSendCode"
                            maxWidth="Infinity"/>
                </VBox>

                <!-- Step 2: code + new password (hidden initially) -->
                <VBox fx:id="stepResetBox" spacing="2.0" visible="false" managed="false">
                    <Label text="RESET CODE"/>
                    <TextField fx:id="codeField" promptText="Enter 6-digit code"
                               style="-fx-font-size:18px;-fx-letter-spacing:6px;-fx-alignment:center;"/>
                    <Region prefHeight="4.0"/>
                    <Label text="NEW PASSWORD"/>
                    <PasswordField fx:id="newPasswordField" promptText="Enter new password"/>
                    <Label text="CONFIRM NEW PASSWORD"/>
                    <PasswordField fx:id="confirmPasswordField" promptText="Repeat new password"/>
                    <Region prefHeight="8.0"/>
                    <Button text="RESET PASSWORD" mnemonicParsing="false" onAction="#handleReset"
                            maxWidth="Infinity"/>
                </VBox>

                <Region prefHeight="6.0"/>

                <Label fx:id="errorLabel" text=""
                       style="-fx-text-fill:#cc2200;-fx-font-size:11px;" wrapText="true"/>

                <Region prefHeight="8.0"/>

                <HBox alignment="CENTER" spacing="4.0">
                    <Button text="Back to Sign In" mnemonicParsing="false" onAction="#handleBack"
                            style="-fx-background-color:transparent;-fx-text-fill:#555;
                                   -fx-font-size:11px;-fx-padding:0;-fx-cursor:hand;
                                   -fx-border-color:transparent;"/>
                </HBox>
            </VBox>
        </VBox>
    </content>
</ScrollPane>

