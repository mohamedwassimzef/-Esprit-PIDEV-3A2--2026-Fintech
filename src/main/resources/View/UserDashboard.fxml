<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="740.0" prefWidth="900.0" stylesheets="@styles.css"
      xmlns="http://javafx.com/javafx/22"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.UserDashboardController">
    <children>

        <!-- Menu Bar -->
        <MenuBar VBox.vgrow="NEVER">
            <menus>
                <Menu mnemonicParsing="false" text="File">
                    <items>
                        <MenuItem mnemonicParsing="false" text="Logout" onAction="#handleLogout"/>
                        <SeparatorMenuItem mnemonicParsing="false"/>
                        <MenuItem mnemonicParsing="false" text="Quit" onAction="#handleQuit"/>
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Help">
                    <items>
                        <MenuItem mnemonicParsing="false" text="About"/>
                    </items>
                </Menu>
            </menus>
        </MenuBar>

        <!-- Welcome banner + Logout button -->
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color:#1a1a1a;-fx-padding:6 16 6 16;-fx-border-color:#2a2a2a;-fx-border-width:0 0 1 0;">
            <children>
                <Label fx:id="welcomeLabel" text="Welcome, User"
                       style="-fx-text-fill:#f5c800;-fx-font-size:13px;-fx-font-weight:700;-fx-letter-spacing:0.5;"
                       HBox.hgrow="ALWAYS"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Logout"
                        mnemonicParsing="false"
                        onAction="#handleLogout"
                        style="-fx-background-color:transparent;-fx-border-color:#f5c800;-fx-border-width:1;-fx-border-radius:4;-fx-text-fill:#f5c800;-fx-font-size:11px;-fx-font-weight:700;-fx-padding:4 14 4 14;-fx-cursor:hand;"/>
            </children>
        </HBox>

        <!-- Tab Pane -->
        <TabPane fx:id="mainTabs" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
            <tabs>

                <!-- ═══════════════════════════════════
                     TAB 1 – MY ASSETS  (list + +/update/delete)
                ═══════════════════════════════════ -->
                <Tab fx:id="assetListTab" text="My Assets">
                    <content>
                        <AnchorPane>
                            <children>
                                <TableView fx:id="assetsTable"
                                           AnchorPane.topAnchor="20.0" AnchorPane.leftAnchor="20.0"
                                           AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="60.0">
                                    <columns>
                                        <TableColumn fx:id="colId"             text="ID"           prefWidth="50.0"  visible="false"/>
                                        <TableColumn fx:id="colReference"      text="Reference"    prefWidth="130.0"/>
                                        <TableColumn fx:id="colType"           text="Type"         prefWidth="70.0"/>
                                        <TableColumn fx:id="colDeclaredValue"  text="Declared"     prefWidth="90.0"/>
                                        <TableColumn fx:id="colDescription"    text="Description"  prefWidth="140.0"/>
                                        <TableColumn fx:id="colLocation"       text="Location"     prefWidth="110.0"/>
                                        <TableColumn fx:id="colManufactureDate" text="Mfr. Date"   prefWidth="90.0"/>
                                        <TableColumn fx:id="colCreatedAt"      text="Created"      prefWidth="110.0"/>
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                    </columnResizePolicy>
                                </TableView>

                                <!-- action bar: + | Update | spacer | Delete -->
                                <HBox spacing="10.0"
                                      AnchorPane.bottomAnchor="12.0"
                                      AnchorPane.leftAnchor="20.0"
                                      AnchorPane.rightAnchor="20.0">
                                    <children>
                                        <Button text="+"
                                                mnemonicParsing="false"
                                                onAction="#handleAddAssetButton"
                                                prefWidth="40.0"
                                                style="-fx-font-size:18px;-fx-font-weight:900;-fx-background-color:#f5c800;-fx-text-fill:#000;-fx-background-radius:5;-fx-cursor:hand;"/>
                                        <Button fx:id="updateAssetButton" disable="true"
                                                mnemonicParsing="false"
                                                onAction="#handleUpdateAssetButton"
                                                text="Update" prefWidth="160.0"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Button fx:id="deleteAssetButton" disable="true"
                                                mnemonicParsing="false"
                                                onAction="#handleDeleteAssetButton"
                                                text="Delete" prefWidth="160.0"/>
                                    </children>
                                </HBox>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>

                <!-- ═══════════════════════════════════
                     TAB 2 – ASSET FORM  (hidden tab, opened by + button)
                ═══════════════════════════════════ -->
                <Tab fx:id="assetFormTab" text="Asset Form" style="-fx-pref-width:0;-fx-min-width:0;-fx-max-width:0;-fx-opacity:0;">
                    <content>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    style="-fx-background:transparent;-fx-background-color:transparent;-fx-border-color:transparent;">
                            <content>
                                <VBox alignment="CENTER" style="-fx-padding:30 60 30 60;">
                                    <children>
                                        <VBox styleClass="form-container"
                                              maxWidth="440.0" spacing="2.0">
                                            <children>
                                                <Label text="REFERENCE"/>
                                                <TextField fx:id="AssReference" promptText="e.g. VH-2024-001"/>

                                                <Label text="TYPE"/>
                                                <ComboBox fx:id="typeCombo" maxWidth="Infinity" promptText="Select type"/>

                                                <Label text="DECLARED VALUE (TND)"/>
                                                <TextField fx:id="AssDeclaredValue" promptText="0.00"/>

                                                <Label text="DESCRIPTION"/>
                                                <TextField fx:id="AssDesc" promptText="Short description"/>

                                                <Label text="MANUFACTURE DATE"/>
                                                <DatePicker fx:id="AssManufDate" maxWidth="Infinity"/>

                                                <Label text="CREATED AT" visible="false"/>
                                                <DatePicker fx:id="AssCreated" visible="false" prefWidth="380.0"/>

                                                <Label text="CITY"/>
                                                <ComboBox fx:id="cityCombo" promptText="Select City" maxWidth="Infinity"/>

                                                <Label text="AREA"/>
                                                <ComboBox fx:id="areaCombo" promptText="Select Area" maxWidth="Infinity"/>

                                                <Region prefHeight="12.0"/>

                                                <Button fx:id="SubAsset" text="Submit Asset"
                                                        mnemonicParsing="false"
                                                        onAction="#handleSubmitButton"
                                                        prefWidth="380.0" maxWidth="Infinity"/>

                                                <Button text="Cancel"
                                                        mnemonicParsing="false"
                                                        onAction="#handleCancelAssetForm"
                                                        prefWidth="380.0" maxWidth="Infinity"
                                                        style="-fx-background-color:transparent;-fx-border-color:#555;-fx-text-fill:#aaa;-fx-border-width:1;-fx-border-radius:4;"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>

                <!-- ═══════════════════════════════════
                     TAB 3 – INSURANCE PACKAGES
                ═══════════════════════════════════ -->
                <Tab fx:id="packagesTab" text="Insurance Packages">
                    <content>
                        <!-- Outer VBox fills the entire tab and stacks sections vertically -->
                        <VBox spacing="0.0" fillWidth="true">

                            <!-- ── Header label ── -->
                            <Label text="Choose a Package Type"
                                   style="-fx-text-fill:#f5c800;-fx-font-size:16px;-fx-font-weight:800;-fx-padding:18 24 10 24;"/>

                            <!-- ── Card row: both cards share equal width and are vertically centred ── -->
                            <HBox spacing="20.0"
                                  alignment="CENTER"
                                  fillHeight="true"
                                  style="-fx-padding:0 24 0 24;">
                                <children>
                                    <VBox fx:id="carCard" styleClass="pkg-type-card"
                                          onMouseClicked="#handleSelectCarPackages"
                                          HBox.hgrow="ALWAYS"
                                          alignment="CENTER"
                                          spacing="8.0"
                                          prefHeight="120.0">
                                        <children>
                                            <Label text="🚗" style="-fx-font-size:32px;"/>
                                            <Label text="CAR"
                                                   style="-fx-text-fill:#f5c800;-fx-font-size:18px;-fx-font-weight:800;"/>
                                            <Label text="Vehicle insurance packages"
                                                   style="-fx-text-fill:#888888;-fx-font-size:11px;"/>
                                        </children>
                                    </VBox>

                                    <VBox fx:id="homeCard" styleClass="pkg-type-card"
                                          onMouseClicked="#handleSelectHomePackages"
                                          HBox.hgrow="ALWAYS"
                                          alignment="CENTER"
                                          spacing="8.0"
                                          prefHeight="120.0">
                                        <children>
                                            <Label text="🏠" style="-fx-font-size:32px;"/>
                                            <Label text="HOME"
                                                   style="-fx-text-fill:#f5c800;-fx-font-size:18px;-fx-font-weight:800;"/>
                                            <Label text="Home &amp; property packages"
                                                   style="-fx-text-fill:#888888;-fx-font-size:11px;"/>
                                        </children>
                                    </VBox>
                                </children>
                            </HBox>

                            <!-- ── Section divider ── -->
                            <Label text="AVAILABLE PACKAGES"
                                   style="-fx-text-fill:#555555;-fx-font-size:10px;-fx-font-weight:800;
                                          -fx-letter-spacing:1.5;-fx-padding:16 24 4 24;"/>
                            <Region prefHeight="1.0"
                                    maxWidth="Infinity"
                                    style="-fx-background-color:#2a2a2a;-fx-padding:0 24 0 24;"
                                    VBox.vgrow="NEVER"/>

                            <!-- ── Scrollable packages list – takes all remaining space ── -->
                            <ScrollPane fx:id="packagesScrollPane"
                                        fitToWidth="true"
                                        hbarPolicy="NEVER"
                                        vbarPolicy="AS_NEEDED"
                                        VBox.vgrow="ALWAYS"
                                        style="-fx-background:transparent;-fx-background-color:transparent;-fx-border-color:transparent;">
                                <content>
                                    <VBox fx:id="packagesListBox"
                                          spacing="20.0"
                                          style="-fx-padding:12 24 12 24;"/>
                                </content>
                            </ScrollPane>

                        </VBox>
                    </content>
                </Tab>

                <!-- ═══════════════════════════════════
                     TAB 4 – REQUEST CONTRACT
                ═══════════════════════════════════ -->
                <Tab fx:id="contractFormTab" text="Request Contract">
                    <content>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    style="-fx-background:transparent;-fx-background-color:transparent;-fx-border-color:transparent;">
                            <content>
                                <VBox alignment="CENTER" style="-fx-padding:30 60 30 60;">
                                    <children>
                                        <VBox styleClass="form-container"
                                              maxWidth="440.0" spacing="2.0">
                                            <children>
                                                <Label text="SELECT YOUR ASSET"/>
                                                <ComboBox fx:id="contractAssetCombo" maxWidth="Infinity"
                                                          promptText="Select your asset"
                                                          onAction="#handleAssetSelectionForRequest"/>

                                                <Label text="INSURANCE PACKAGE"/>
                                                <ComboBox fx:id="contractPackageCombo" maxWidth="Infinity"
                                                          promptText="Select a package"
                                                          onAction="#handlePackageSelectionForRequest"/>

                                                <HBox spacing="16.0">
                                                    <children>
                                                        <VBox HBox.hgrow="ALWAYS" spacing="2.0">
                                                            <children>
                                                                <Label text="CALCULATED PREMIUM"/>
                                                                <TextField fx:id="reqPremiumField" promptText="auto-calculated"
                                                                           editable="false"
                                                                           style="-fx-background-color:#1a1a1a;-fx-text-fill:#f5c800;"/>
                                                            </children>
                                                        </VBox>
                                                        <VBox HBox.hgrow="ALWAYS" spacing="2.0">
                                                            <children>
                                                                <Label text="DURATION (months)"/>
                                                                <TextField fx:id="reqDurationField" promptText="auto-filled"
                                                                           editable="false"
                                                                           style="-fx-background-color:#1a1a1a;-fx-text-fill:#f5c800;"/>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </HBox>

                                                <HBox spacing="16.0">
                                                    <children>
                                                        <VBox HBox.hgrow="ALWAYS" spacing="2.0">
                                                            <children>
                                                                <Label text="START DATE"/>
                                                                <DatePicker fx:id="reqStartDate" maxWidth="Infinity"/>
                                                            </children>
                                                        </VBox>
                                                        <VBox HBox.hgrow="ALWAYS" spacing="2.0">
                                                            <children>
                                                                <Label text="END DATE (auto)"/>
                                                                <TextField fx:id="reqEndDateField" promptText="auto from duration"
                                                                           editable="false"
                                                                           style="-fx-background-color:#1a1a1a;-fx-text-fill:#f5c800;"/>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </HBox>

                                                <Region prefHeight="12.0"/>

                                                <Button text="Submit Request"
                                                        mnemonicParsing="false"
                                                        onAction="#handleSubmitContractRequest"
                                                        prefWidth="380.0" maxWidth="Infinity"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>

                <!-- ═══════════════════════════════════
                     TAB 5 – MY REQUESTS
                ═══════════════════════════════════ -->
                <Tab fx:id="myRequestsTab" text="My Requests">
                    <content>
                        <AnchorPane>
                            <children>
                                <TableView fx:id="requestsTable"
                                           AnchorPane.topAnchor="20.0" AnchorPane.leftAnchor="20.0"
                                           AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="20.0">
                                    <columns>
                                        <TableColumn fx:id="reqColId"        text="ID"        prefWidth="50.0" visible="false"/>
                                        <TableColumn fx:id="reqColAssetId"   text="Asset ID"  prefWidth="80.0"/>
                                        <TableColumn fx:id="reqColPackageId" text="Package"   prefWidth="90.0"/>
                                        <TableColumn fx:id="reqColPremium"   text="Premium"   prefWidth="100.0"/>
                                        <TableColumn fx:id="reqColStatus"    text="Status"    prefWidth="100.0"/>
                                        <TableColumn fx:id="reqColCreatedAt" text="Submitted" prefWidth="130.0"/>
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>

            </tabs>
        </TabPane>

    </children>
</VBox>
