<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="740.0" prefWidth="1100.0"
            stylesheets="@styles.css"
            xmlns="http://javafx.com/javafx/22"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.UserDashboardController">

    <!-- TOP BAR -->
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
            <Label text="FinTech" styleClass="topbar-brand"/>
            <Label text="/ Insurance" styleClass="topbar-module"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" text="Welcome, User" styleClass="topbar-welcome"/>
            <Button text="Logout" styleClass="btn-outline-gold"
                    mnemonicParsing="false" onAction="#handleLogout"/>
        </HBox>
    </top>

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" prefWidth="185.0" spacing="4">
            <Label text="SERVICES" styleClass="sidebar-section-label"/>
            <Button text="Shield  Insurance" styleClass="sidebar-btn sidebar-btn-active"
                    mnemonicParsing="false" maxWidth="Infinity"/>
            <Button text="Personal Finance" styleClass="sidebar-btn"
                    mnemonicParsing="false" maxWidth="Infinity" onAction="#goPersonalFinance"/>
            <Button text="Loans" styleClass="sidebar-btn"
                    mnemonicParsing="false" maxWidth="Infinity" onAction="#goLoans"/>
            <Button text="Transactions" styleClass="sidebar-btn"
                    mnemonicParsing="false" maxWidth="Infinity" onAction="#goTransactions"/>
            <Label text="COMING SOON" styleClass="sidebar-section-label" style="-fx-padding:18 0 4 0;"/>
            <Button text="Personal Finance" styleClass="sidebar-btn sidebar-btn-disabled"
                    mnemonicParsing="false" maxWidth="Infinity" disable="true"/>
            <Button text="Transactions" styleClass="sidebar-btn sidebar-btn-disabled"
                    mnemonicParsing="false" maxWidth="Infinity" disable="true"/>
            <Button text="Complaints" styleClass="sidebar-btn sidebar-btn-disabled"
                    mnemonicParsing="false" maxWidth="Infinity" disable="true"/>
            <Button text="Loans" styleClass="sidebar-btn sidebar-btn-disabled"
                    mnemonicParsing="false" maxWidth="Infinity" disable="true"/>
            <Button text="Statistics" styleClass="sidebar-btn sidebar-btn-disabled"
                    mnemonicParsing="false" maxWidth="Infinity" disable="true"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="Back to Home" styleClass="sidebar-btn"
                    mnemonicParsing="false" maxWidth="Infinity" onAction="#handleBackHome"/>
        </VBox>
    </left>

    <!-- CENTER: Insurance TabPane -->
    <center>
        <TabPane fx:id="mainTabs" tabClosingPolicy="UNAVAILABLE">
            <tabs>

                <!-- TAB 1: MY ASSETS -->
                <Tab fx:id="assetListTab" text="My Assets">
                    <content>
                        <AnchorPane>
                            <children>
                                <TableView fx:id="assetsTable"
                                           AnchorPane.topAnchor="20.0" AnchorPane.leftAnchor="20.0"
                                           AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="60.0">
                                    <columns>
                                        <TableColumn fx:id="colId"              text="ID"          prefWidth="50.0" visible="false"/>
                                        <TableColumn fx:id="colReference"       text="Reference"   prefWidth="130.0"/>
                                        <TableColumn fx:id="colType"            text="Type"        prefWidth="70.0"/>
                                        <TableColumn fx:id="colDeclaredValue"   text="Declared"    prefWidth="90.0"/>
                                        <TableColumn fx:id="colDescription"     text="Description" prefWidth="140.0"/>
                                        <TableColumn fx:id="colLocation"        text="Location"    prefWidth="110.0"/>
                                        <TableColumn fx:id="colManufactureDate" text="Mfr. Date"   prefWidth="90.0"/>
                                        <TableColumn fx:id="colCreatedAt"       text="Created"     prefWidth="110.0"/>
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                    </columnResizePolicy>
                                </TableView>
                                <HBox spacing="10.0" AnchorPane.bottomAnchor="12.0"
                                      AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0">
                                    <Button text="+" mnemonicParsing="false" onAction="#handleAddAssetButton"
                                            prefWidth="40.0"
                                            style="-fx-font-size:18px;-fx-font-weight:900;-fx-background-color:#f5c800;-fx-text-fill:#000;-fx-background-radius:5;-fx-cursor:hand;"/>
                                    <Button fx:id="updateAssetButton" disable="true"
                                            mnemonicParsing="false" onAction="#handleUpdateAssetButton"
                                            text="Update" prefWidth="160.0"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button fx:id="deleteAssetButton" disable="true"
                                            mnemonicParsing="false" onAction="#handleDeleteAssetButton"
                                            text="Delete" prefWidth="160.0"/>
                                </HBox>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>

                <!-- TAB 2: ASSET FORM (hidden) -->
                <Tab fx:id="assetFormTab" text="Asset Form"
                     style="-fx-pref-width:0;-fx-min-width:0;-fx-max-width:0;-fx-opacity:0;">
                    <content>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    style="-fx-background:transparent;-fx-background-color:transparent;">
                            <content>
                                <VBox alignment="CENTER" style="-fx-padding:30 60 30 60;">
                                    <VBox styleClass="form-container" maxWidth="440.0" spacing="2.0">
                                        <Label text="REFERENCE"/>
                                        <TextField fx:id="AssReference" promptText="e.g. VH-2024-001"/>
                                        <Label text="TYPE"/>
                                        <ComboBox fx:id="typeCombo" maxWidth="Infinity" promptText="Select type"/>
                                        <Label text="DECLARED VALUE (TND)"/>
                                        <TextField fx:id="AssDeclaredValue" promptText="0.00"/>
                                        <Label text="DESCRIPTION"/>
                                        <TextField fx:id="AssDesc" promptText="Short description"/>
                                        <Label text="MANUFACTURE DATE"/>
                                        <DatePicker fx:id="AssManufDate" maxWidth="Infinity"/>
                                        <Label text="CREATED AT" visible="false"/>
                                        <DatePicker fx:id="AssCreated" visible="false" prefWidth="380.0"/>
                                        <Label text="CITY"/>
                                        <ComboBox fx:id="cityCombo" promptText="Select City" maxWidth="Infinity"/>
                                        <Label text="AREA"/>
                                        <ComboBox fx:id="areaCombo" promptText="Select Area" maxWidth="Infinity"/>
                                        <Region prefHeight="12.0"/>
                                        <Button fx:id="SubAsset" text="Submit Asset"
                                                mnemonicParsing="false" onAction="#handleSubmitButton"
                                                prefWidth="380.0" maxWidth="Infinity"/>
                                        <Button text="Cancel" mnemonicParsing="false"
                                                onAction="#handleCancelAssetForm"
                                                prefWidth="380.0" maxWidth="Infinity"
                                                style="-fx-background-color:transparent;-fx-border-color:#555;-fx-text-fill:#aaa;-fx-border-width:1;-fx-border-radius:4;"/>
                                    </VBox>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>

                <!-- TAB 3: INSURANCE PACKAGES -->
                <Tab fx:id="packagesTab" text="Insurance Packages">
                    <content>
                        <VBox spacing="0.0" fillWidth="true">
                            <Label text="Choose a Package Type"
                                   style="-fx-text-fill:#f5c800;-fx-font-size:16px;-fx-font-weight:800;-fx-padding:18 24 10 24;"/>
                            <HBox spacing="20.0" alignment="CENTER" style="-fx-padding:0 24 0 24;">
                                <VBox fx:id="carCard" styleClass="pkg-type-card" onMouseClicked="#handleSelectCarPackages"
                                      HBox.hgrow="ALWAYS" alignment="CENTER" spacing="8.0" prefHeight="120.0">
                                    <Label text="Car" style="-fx-font-size:32px;"/>
                                    <Label text="CAR" style="-fx-text-fill:#f5c800;-fx-font-size:18px;-fx-font-weight:800;"/>
                                    <Label text="Vehicle insurance packages" style="-fx-text-fill:#888;-fx-font-size:11px;"/>
                                </VBox>
                                <VBox fx:id="homeCard" styleClass="pkg-type-card" onMouseClicked="#handleSelectHomePackages"
                                      HBox.hgrow="ALWAYS" alignment="CENTER" spacing="8.0" prefHeight="120.0">
                                    <Label text="Home" style="-fx-font-size:32px;"/>
                                    <Label text="HOME" style="-fx-text-fill:#f5c800;-fx-font-size:18px;-fx-font-weight:800;"/>
                                    <Label text="Home and property packages" style="-fx-text-fill:#888;-fx-font-size:11px;"/>
                                </VBox>
                            </HBox>
                            <Label text="AVAILABLE PACKAGES"
                                   style="-fx-text-fill:#555;-fx-font-size:10px;-fx-font-weight:800;-fx-letter-spacing:1.5;-fx-padding:16 24 4 24;"/>
                            <Region prefHeight="1.0" maxWidth="Infinity" style="-fx-background-color:#2a2a2a;" VBox.vgrow="NEVER"/>
                            <ScrollPane fx:id="packagesScrollPane" fitToWidth="true"
                                        hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS"
                                        style="-fx-background:transparent;-fx-background-color:transparent;">
                                <content>
                                    <VBox fx:id="packagesListBox" spacing="20.0" style="-fx-padding:12 24 12 24;"/>
                                </content>
                            </ScrollPane>
                        </VBox>
                    </content>
                </Tab>

                <!-- TAB 4: REQUEST CONTRACT -->
                <Tab fx:id="contractFormTab" text="Request Contract">
                    <content>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    style="-fx-background:transparent;-fx-background-color:transparent;">
                            <content>
                                <VBox alignment="CENTER" style="-fx-padding:30 60 30 60;">
                                    <VBox styleClass="form-container" maxWidth="440.0" spacing="2.0">
                                        <Label text="SELECT YOUR ASSET"/>
                                        <ComboBox fx:id="contractAssetCombo" maxWidth="Infinity"
                                                  promptText="Select your asset"
                                                  onAction="#handleAssetSelectionForRequest"/>
                                        <Label text="INSURANCE PACKAGE"/>
                                        <ComboBox fx:id="contractPackageCombo" maxWidth="Infinity"
                                                  promptText="Select a package"
                                                  onAction="#handlePackageSelectionForRequest"/>
                                        <HBox spacing="16.0">
                                            <VBox HBox.hgrow="ALWAYS" spacing="2.0">
                                                <Label text="CALCULATED PREMIUM"/>
                                                <TextField fx:id="reqPremiumField" promptText="auto-calculated"
                                                           editable="false"
                                                           style="-fx-background-color:#1a1a1a;-fx-text-fill:#f5c800;"/>
                                            </VBox>
                                            <VBox HBox.hgrow="ALWAYS" spacing="2.0">
                                                <Label text="DURATION (months)"/>
                                                <TextField fx:id="reqDurationField" promptText="auto-filled"
                                                           editable="false"
                                                           style="-fx-background-color:#1a1a1a;-fx-text-fill:#f5c800;"/>
                                            </VBox>
                                        </HBox>
                                        <HBox spacing="16.0">
                                            <VBox HBox.hgrow="ALWAYS" spacing="2.0">
                                                <Label text="START DATE"/>
                                                <DatePicker fx:id="reqStartDate" maxWidth="Infinity"/>
                                            </VBox>
                                            <VBox HBox.hgrow="ALWAYS" spacing="2.0">
                                                <Label text="END DATE (auto)"/>
                                                <TextField fx:id="reqEndDateField" promptText="auto from duration"
                                                           editable="false"
                                                           style="-fx-background-color:#1a1a1a;-fx-text-fill:#f5c800;"/>
                                            </VBox>
                                        </HBox>
                                        <Region prefHeight="12.0"/>
                                        <Button text="Submit Request" mnemonicParsing="false"
                                                onAction="#handleSubmitContractRequest"
                                                prefWidth="380.0" maxWidth="Infinity"/>
                                    </VBox>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>

                <!-- TAB 5: MY REQUESTS -->
                <Tab fx:id="myRequestsTab" text="My Requests">
                    <content>
                        <AnchorPane>
                            <children>
                                <TableView fx:id="requestsTable"
                                           AnchorPane.topAnchor="20.0" AnchorPane.leftAnchor="20.0"
                                           AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="20.0">
                                    <columns>
                                        <TableColumn fx:id="reqColId"        text="ID"        prefWidth="50.0" visible="false"/>
                                        <TableColumn fx:id="reqColAssetId"   text="Asset"     prefWidth="100.0"/>
                                        <TableColumn fx:id="reqColPackageId" text="Package"   prefWidth="140.0"/>
                                        <TableColumn fx:id="reqColPremium"   text="Premium"   prefWidth="100.0"/>
                                        <TableColumn fx:id="reqColStatus"    text="Status"    prefWidth="100.0"/>
                                        <TableColumn fx:id="reqColCreatedAt" text="Submitted" prefWidth="130.0"/>
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>

            </tabs>
        </TabPane>
    </center>

</BorderPane>
