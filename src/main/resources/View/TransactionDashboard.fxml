<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="740.0" prefWidth="1100.0"
            stylesheets="@styles.css"
            xmlns="http://javafx.com/javafx/22"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.TransactionController">

    <!-- TOP BAR -->
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
            <Label text="FinTech" styleClass="topbar-brand"/>
            <Label text="/ Transactions" styleClass="topbar-module"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" text="Welcome, User" styleClass="topbar-welcome"/>
            <Button text="Logout" styleClass="btn-outline-gold"
                    mnemonicParsing="false" onAction="#handleLogout"/>
        </HBox>
    </top>

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" prefWidth="185.0" spacing="4">
            <Label text="SERVICES" styleClass="sidebar-section-label"/>
            <Button text="Insurance"        styleClass="sidebar-btn" mnemonicParsing="false" maxWidth="Infinity" onAction="#goInsurance"/>
            <Button text="Personal Finance" styleClass="sidebar-btn" mnemonicParsing="false" maxWidth="Infinity" onAction="#goPersonalFinance"/>
            <Button text="Loans"            styleClass="sidebar-btn" mnemonicParsing="false" maxWidth="Infinity" onAction="#goLoans"/>
            <Button text="Transactions"     styleClass="sidebar-btn sidebar-btn-active" mnemonicParsing="false" maxWidth="Infinity"/>
            <Label text="COMING SOON" styleClass="sidebar-section-label" style="-fx-padding:18 0 4 0;"/>
            <Button text="Statistics" styleClass="sidebar-btn sidebar-btn-disabled" mnemonicParsing="false" maxWidth="Infinity" disable="true"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="Back to Home" styleClass="sidebar-btn" mnemonicParsing="false" maxWidth="Infinity" onAction="#handleBackHome"/>
        </VBox>
    </left>

    <!-- CENTER -->
    <center>
        <TabPane fx:id="mainTabs" tabClosingPolicy="UNAVAILABLE">
            <tabs>

                <!-- ═══════════ TAB 1 – MY TRANSACTIONS ═══════════ -->
                <Tab fx:id="txListTab" text="My Transactions">
                    <content>
                        <AnchorPane>
                            <children>

                                <!-- Summary strip -->
                                <HBox spacing="16" AnchorPane.topAnchor="12"
                                      AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20"
                                      style="-fx-padding:14 18 14 18;-fx-background-color:#1a1a1a;-fx-border-color:#2a2a2a;-fx-border-radius:6;-fx-background-radius:6;">
                                    <VBox alignment="CENTER" spacing="2" HBox.hgrow="ALWAYS">
                                        <Label text="TOTAL CREDITED" styleClass="stat-label"/>
                                        <Label fx:id="totalCreditLabel" text="0.00 TND" styleClass="stat-value-success"/>
                                    </VBox>
                                    <Region style="-fx-background-color:#2a2a2a;" prefWidth="1" prefHeight="40"/>
                                    <VBox alignment="CENTER" spacing="2" HBox.hgrow="ALWAYS">
                                        <Label text="TOTAL DEBITED" styleClass="stat-label"/>
                                        <Label fx:id="totalDebitLabel" text="0.00 TND" styleClass="stat-value-danger"/>
                                    </VBox>
                                    <Region style="-fx-background-color:#2a2a2a;" prefWidth="1" prefHeight="40"/>
                                    <VBox alignment="CENTER" spacing="2" HBox.hgrow="ALWAYS">
                                        <Label text="PENDING" styleClass="stat-label"/>
                                        <Label fx:id="pendingCountLabel" text="0" styleClass="stat-value"/>
                                    </VBox>
                                    <Region style="-fx-background-color:#2a2a2a;" prefWidth="1" prefHeight="40"/>
                                    <VBox alignment="CENTER" spacing="2" HBox.hgrow="ALWAYS">
                                        <Label text="COMPLETED" styleClass="stat-label"/>
                                        <Label fx:id="completedCountLabel" text="0" styleClass="stat-value-success"/>
                                    </VBox>
                                </HBox>

                                <!-- Transaction table -->
                                <TableView fx:id="txTable"
                                           AnchorPane.topAnchor="90" AnchorPane.leftAnchor="20"
                                           AnchorPane.rightAnchor="20" AnchorPane.bottomAnchor="60">
                                    <columns>
                                        <TableColumn fx:id="txColId"          text="ID"          prefWidth="50"  visible="false"/>
                                        <TableColumn fx:id="txColType"        text="Type"        prefWidth="80"/>
                                        <TableColumn fx:id="txColAmount"      text="Amount"      prefWidth="110"/>
                                        <TableColumn fx:id="txColCurrency"    text="Currency"    prefWidth="80"/>
                                        <TableColumn fx:id="txColStatus"      text="Status"      prefWidth="90"/>
                                        <TableColumn fx:id="txColDescription" text="Description" prefWidth="180"/>
                                        <TableColumn fx:id="txColRefType"     text="Reference"   prefWidth="100"/>
                                        <TableColumn fx:id="txColCreatedAt"   text="Date"        prefWidth="130"/>
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                    </columnResizePolicy>
                                </TableView>

                                <!-- Action bar -->
                                <HBox spacing="10" AnchorPane.bottomAnchor="12"
                                      AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20">
                                    <Button text="+ New Transaction" mnemonicParsing="false" onAction="#handleAddTransaction"
                                            style="-fx-background-color:#f5c800;-fx-text-fill:#000;-fx-font-weight:900;-fx-background-radius:5;-fx-cursor:hand;-fx-padding:7 16 7 16;"/>
                                    <Button fx:id="complainBtn" text="File Complaint" prefWidth="150"
                                            mnemonicParsing="false" onAction="#handleFileComplaint"
                                            style="-fx-background-color:transparent;-fx-border-color:#f5c800;-fx-border-width:1;-fx-text-fill:#f5c800;-fx-border-radius:4;"
                                            disable="true"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button fx:id="deleteTxBtn" text="Delete" prefWidth="120"
                                            mnemonicParsing="false" onAction="#handleDeleteTransaction" disable="true"/>
                                </HBox>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>

                <!-- ═══════════ TAB 2 – NEW TRANSACTION FORM ═══════════ -->
                <Tab fx:id="txFormTab" text="New Transaction"
                     style="-fx-pref-width:0;-fx-min-width:0;-fx-max-width:0;-fx-opacity:0;">
                    <content>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    style="-fx-background:transparent;-fx-background-color:transparent;">
                            <content>
                                <VBox alignment="CENTER" style="-fx-padding:30 60 30 60;">
                                    <VBox styleClass="form-container" maxWidth="500" spacing="2">
                                        <Label text="NEW PAYMENT / TRANSACTION"
                                               style="-fx-text-fill:#f5c800;-fx-font-size:14px;-fx-font-weight:900;-fx-padding:0 0 10 0;"/>

                                        <!-- Paymee payment fields -->
                                        <Label text="AMOUNT (TND)"/>
                                        <TextField fx:id="txAmount" promptText="e.g. 250.00"/>

                                        <Label text="TRANSACTION TYPE"/>
                                        <ComboBox fx:id="txType" maxWidth="Infinity" promptText="DEBIT or CREDIT"/>

                                        <Label text="CURRENCY"/>
                                        <ComboBox fx:id="txCurrency" maxWidth="Infinity" promptText="Select currency"/>

                                        <Label text="REFERENCE TYPE"/>
                                        <ComboBox fx:id="txRefType" maxWidth="Infinity" promptText="What is this payment for?"/>

                                        <Label text="DESCRIPTION / NOTE"/>
                                        <TextField fx:id="txDescription" promptText="Payment note or description"/>

                                        <!-- Divider -->
                                        <Label text="RECIPIENT INFORMATION (for Paymee)"
                                               style="-fx-text-fill:#555;-fx-font-size:9px;-fx-font-weight:900;-fx-letter-spacing:1.2;-fx-padding:14 0 4 0;"/>
                                        <Region prefHeight="1" maxWidth="Infinity" style="-fx-background-color:#2a2a2a;"/>
                                        <Region prefHeight="6"/>

                                        <HBox spacing="16">
                                            <VBox HBox.hgrow="ALWAYS" spacing="2">
                                                <Label text="FIRST NAME"/>
                                                <TextField fx:id="txFirstName" promptText="First name"/>
                                            </VBox>
                                            <VBox HBox.hgrow="ALWAYS" spacing="2">
                                                <Label text="LAST NAME"/>
                                                <TextField fx:id="txLastName" promptText="Last name"/>
                                            </VBox>
                                        </HBox>

                                        <Label text="EMAIL"/>
                                        <TextField fx:id="txEmail" promptText="recipient@example.com"/>

                                        <Label text="PHONE"/>
                                        <TextField fx:id="txPhone" promptText="+216XXXXXXXX"/>

                                        <Label text="ORDER ID (optional)"/>
                                        <TextField fx:id="txOrderId" promptText="auto-generated if empty"/>

                                        <!-- Paymee URLs (auto-filled) -->
                                        <Label text="RETURN URL"/>
                                        <TextField fx:id="txReturnUrl" promptText="https://yoursite.com/success"
                                                   text="https://app.fintech.tn/payment/success"/>
                                        <Label text="CANCEL URL"/>
                                        <TextField fx:id="txCancelUrl" promptText="https://yoursite.com/cancel"
                                                   text="https://app.fintech.tn/payment/cancel"/>

                                        <Region prefHeight="12"/>

                                        <!-- API Response panel -->
                                        <VBox fx:id="apiResponseBox"
                                              style="-fx-background-color:#0d0d0d;-fx-border-color:#2a2a2a;-fx-border-radius:6;-fx-background-radius:6;-fx-padding:12 14 12 14;"
                                              spacing="6" visible="false" managed="false">
                                            <Label text="PAYMEE RESPONSE" style="-fx-text-fill:#555;-fx-font-size:9px;-fx-font-weight:900;-fx-letter-spacing:1.2;"/>
                                            <Label fx:id="apiStatusLabel" text="" style="-fx-text-fill:#f5c800;-fx-font-weight:700;"/>
                                            <Label fx:id="apiPaymentUrlLabel" text="" wrapText="true"
                                                   style="-fx-text-fill:#33dd77;-fx-font-size:11px;" onMouseClicked="#handleOpenPaymentUrl"/>
                                        </VBox>

                                        <Button text="Send Payment via Paymee" fx:id="submitTxBtn"
                                                mnemonicParsing="false" onAction="#handleSubmitTransaction"
                                                maxWidth="Infinity"
                                                style="-fx-background-color:#f5c800;-fx-text-fill:#000;-fx-font-weight:900;-fx-background-radius:5;"/>
                                        <Button text="Cancel" mnemonicParsing="false"
                                                onAction="#handleCancelTxForm" maxWidth="Infinity"
                                                style="-fx-background-color:transparent;-fx-border-color:#555;-fx-text-fill:#aaa;-fx-border-width:1;-fx-border-radius:4;"/>
                                    </VBox>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>

                <!-- ═══════════ TAB 3 – MY COMPLAINTS ═══════════ -->
                <Tab fx:id="complaintListTab" text="My Complaints">
                    <content>
                        <AnchorPane>
                            <children>
                                <!-- Filter bar -->
                                <HBox spacing="12" alignment="CENTER_LEFT"
                                      AnchorPane.topAnchor="12" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20"
                                      style="-fx-padding:10 16 10 16;-fx-background-color:#1a1a1a;-fx-border-color:#2a2a2a;-fx-border-radius:6;-fx-background-radius:6;">
                                    <Label text="FILTER BY STATUS:" styleClass="stat-label"/>
                                    <ComboBox fx:id="complaintStatusFilter" promptText="All"
                                              onAction="#handleComplaintFilterChange" prefWidth="160"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label text="TOTAL COMPLAINTS:" styleClass="stat-label"/>
                                    <Label fx:id="complaintCountLabel" text="0"
                                           style="-fx-text-fill:#f5c800;-fx-font-size:14px;-fx-font-weight:900;"/>
                                </HBox>

                                <!-- Complaint table -->
                                <TableView fx:id="complaintTable"
                                           AnchorPane.topAnchor="72" AnchorPane.leftAnchor="20"
                                           AnchorPane.rightAnchor="20" AnchorPane.bottomAnchor="60">
                                    <columns>
                                        <TableColumn fx:id="cColId"       text="ID"       prefWidth="50"  visible="false"/>
                                        <TableColumn fx:id="cColSubject"  text="Subject"  prefWidth="220"/>
                                        <TableColumn fx:id="cColStatus"   text="Status"   prefWidth="100"/>
                                        <TableColumn fx:id="cColDate"     text="Date"     prefWidth="100"/>
                                        <TableColumn fx:id="cColResponse" text="Response" prefWidth="220"/>
                                        <TableColumn fx:id="cColCreatedAt" text="Submitted" prefWidth="130"/>
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                    </columnResizePolicy>
                                </TableView>

                                <!-- Action bar -->
                                <HBox spacing="10" AnchorPane.bottomAnchor="12"
                                      AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20">
                                    <Button text="+ New Complaint" mnemonicParsing="false" onAction="#handleAddComplaint"
                                            style="-fx-background-color:#f5c800;-fx-text-fill:#000;-fx-font-weight:900;-fx-background-radius:5;-fx-cursor:hand;-fx-padding:7 16 7 16;"/>
                                    <Button fx:id="updateComplaintBtn" text="Update" prefWidth="120"
                                            mnemonicParsing="false" onAction="#handleUpdateComplaint" disable="true"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button fx:id="deleteComplaintBtn" text="Delete" prefWidth="120"
                                            mnemonicParsing="false" onAction="#handleDeleteComplaint" disable="true"/>
                                </HBox>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>

                <!-- ═══════════ TAB 4 – COMPLAINT FORM ═══════════ -->
                <Tab fx:id="complaintFormTab" text="Complaint Form"
                     style="-fx-pref-width:0;-fx-min-width:0;-fx-max-width:0;-fx-opacity:0;">
                    <content>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    style="-fx-background:transparent;-fx-background-color:transparent;">
                            <content>
                                <VBox alignment="CENTER" style="-fx-padding:30 60 30 60;">
                                    <VBox styleClass="form-container" maxWidth="480" spacing="2">
                                        <Label fx:id="complaintFormTitle" text="FILE A COMPLAINT"
                                               style="-fx-text-fill:#f5c800;-fx-font-size:14px;-fx-font-weight:900;-fx-padding:0 0 8 0;"/>

                                        <Label text="RELATED TRANSACTION (optional)"/>
                                        <ComboBox fx:id="cTxCombo" maxWidth="Infinity" promptText="Select a transaction"/>

                                        <Label text="SUBJECT"/>
                                        <TextField fx:id="cSubject" promptText="Brief description of the issue"/>

                                        <Label text="DETAILS"/>
                                        <TextArea fx:id="cDetails" promptText="Describe the problem in detail..."
                                                  prefRowCount="4" wrapText="true"
                                                  style="-fx-background-color:#1e1e1e;-fx-border-color:#333;-fx-text-fill:#e0e0e0;-fx-border-radius:4;"/>

                                        <Label text="DATE"/>
                                        <DatePicker fx:id="cDate" maxWidth="Infinity"/>

                                        <Region prefHeight="12"/>
                                        <Button fx:id="submitComplaintBtn" text="Submit Complaint"
                                                mnemonicParsing="false" onAction="#handleSubmitComplaint"
                                                maxWidth="Infinity"/>
                                        <Button text="Cancel" mnemonicParsing="false"
                                                onAction="#handleCancelComplaintForm" maxWidth="Infinity"
                                                style="-fx-background-color:transparent;-fx-border-color:#555;-fx-text-fill:#aaa;-fx-border-width:1;-fx-border-radius:4;"/>
                                    </VBox>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>

            </tabs>
        </TabPane>
    </center>

</BorderPane>

