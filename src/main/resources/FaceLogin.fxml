<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="tn.esprit.controllers.FaceLoginController"
           prefWidth="900" prefHeight="600"
           style="-fx-background-color: #F3F4F6;">
    <VBox alignment="CENTER">
        <VBox alignment="TOP_CENTER" maxWidth="420" spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 20;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0, 0, 5);">

            <HBox alignment="CENTER" prefHeight="70"
                  style="-fx-background-color: #7C3AED; -fx-background-radius: 20 20 0 0;">
                <Label text="🤳  Face Login"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            </HBox>

            <VBox spacing="14">
                <padding><Insets top="30" right="35" bottom="30" left="35"/></padding>

                <Label text="Enter your email — we’ll load your face model:"
                       style="-fx-font-size: 14px; -fx-text-fill: #374151;"/>

                <TextField fx:id="emailField" promptText="your@email.com"
                           style="-fx-background-radius: 10; -fx-border-color: #D1D5DB;
                                  -fx-border-radius: 10; -fx-padding: 12;"/>

                <Label text="⚠ Make sure your webcam is connected and your face is well-lit."
                       wrapText="true"
                       style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"/>

                <Label fx:id="statusLabel" text="" wrapText="true"
                       style="-fx-font-size: 13px; -fx-font-weight: bold;"/>

                <Button fx:id="scanBtn" text="📷  Scan My Face"
                        prefWidth="350" prefHeight="45"
                        style="-fx-background-color: #7C3AED; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-font-size: 15px;
                               -fx-background-radius: 12; -fx-cursor: hand;"
                        onAction="#handleScanFace"/>

                <Button text="← Back to Login"
                        prefWidth="350" prefHeight="38"
                        style="-fx-background-color: transparent; -fx-text-fill: #6B7280;
                               -fx-border-color: #D1D5DB; -fx-border-radius: 10;
                               -fx-background-radius: 10; -fx-cursor: hand;"
                        onAction="#handleBackToLogin"/>
            </VBox>
        </VBox>
    </VBox>
</StackPane>
